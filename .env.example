# Used in Phase 2 (admin area). Safe to leave blank for now.
ADMIN_PASSWORD=change-me

# Cookie signing secret (32+ random chars). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=change-me

# Public base URL for photos. Set once you add a custom domain to the R2 bucket,
# e.g. https://photos.lucaseatsbig.com
PUBLIC_PHOTOS_URL=

---
import { env } from 'cloudflare:workers';
import { marked } from 'marked';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Masthead from '../../components/Masthead.astro';
import HomeListCard from '../../components/HomeListCard.astro';
import { getPostBySlug, getFeaturedRestaurantsForPost, getRelatedPosts } from '../../lib/posts';
import { searchRestaurants } from '../../lib/db';
import { placePhotoUrl } from '../../lib/places';
import RelatedGuides from '../../components/RelatedGuides.astro';

const slug = Astro.params.slug;
if (!slug) return Astro.redirect('/guides');

const post = await getPostBySlug(env.DB, slug);
if (!post) return new Response('Not found', { status: 404 });

const photosBase = env.PUBLIC_PHOTOS_URL ?? '';

// Featured restaurant cards rendered below the markdown body. We still link
// from inside the markdown via standard Astro routing — these cards are the
// visual confirmation of what the guide covers.
const featured = await getFeaturedRestaurantsForPost(env.DB, post.featured_restaurant_ids);

// HomeListCard wants the full RestaurantCardData shape. Fetch it for just
// the featured set so the cards render with ratings, tags, etc.
const featuredFullCards = post.featured_restaurant_ids.length > 0
  ? (await searchRestaurants(env.DB, {})).filter((r) =>
      post.featured_restaurant_ids.includes(r.id)
    )
  : [];
const featuredFullCardsById = new Map(featuredFullCards.map((c) => [c.id, c]));
const orderedCards = post.featured_restaurant_ids
  .map((id) => featuredFullCardsById.get(id))
  .filter((c): c is NonNullable<typeof c> => !!c);

// Hero image: same source priority as restaurant detail pages (uploaded
// cover → Google Places → none).
let heroSrc: string | null = null;
if (post.og_image_cover_r2_key && photosBase) {
  heroSrc = `${photosBase}/${post.og_image_cover_r2_key}`;
} else if (post.og_image_hero_photo_name) {
  heroSrc = placePhotoUrl(post.og_image_hero_photo_name, 1600);
}

// Render markdown server-side. Configure marked to add a class to internal
// restaurant links so we can style them distinctly. Runs as plain HTML —
// markdown is generated by our own pipeline so we don't need DOMPurify.
marked.setOptions({ gfm: true, breaks: false });
const bodyHtml = marked.parse(post.body_md) as string;

// JSON-LD ItemList — surfaces the guide as a ranked restaurant list to
// search engines. Each item points back at the restaurant detail URL.
const itemListLd = orderedCards.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'ItemList',
      name: post.title,
      itemListOrder: 'https://schema.org/ItemListOrderDescending',
      numberOfItems: orderedCards.length,
      itemListElement: orderedCards.map((r, i) => ({
        '@type': 'ListItem',
        position: i + 1,
        url: `https://lucaseatsbig.com/restaurants/${r.slug}`,
        name: r.name,
      })),
    }
  : null;

// FAQ extraction — generators put a `## Frequently asked` section near the
// end when PAA suggestions were available. We parse it into a FAQPage
// JSON-LD blob so Google can show rich-result questions in search results.
function extractFaq(md: string): { question: string; answer: string }[] {
  const headingRe = /(^|\n)##\s+(?:Frequently asked|FAQs?|Questions?)\s*\n/i;
  const m = md.match(headingRe);
  if (!m) return [];
  const tail = md.slice((m.index ?? 0) + m[0].length);
  // Stop at the next H2 if there is one.
  const stop = tail.search(/\n##\s+/);
  const section = stop >= 0 ? tail.slice(0, stop) : tail;
  const out: { question: string; answer: string }[] = [];
  // Pattern: "### Question" then paragraph, OR "**Question**" then paragraph.
  const qa = section.split(/\n(?=###\s+|\*\*[A-Z])/);
  for (const block of qa) {
    const headingMatch = block.match(/^(?:###\s+|\*\*)([^\n*]+?)(?:\*\*)?\s*\n([\s\S]+)$/);
    if (!headingMatch) continue;
    const question = headingMatch[1].trim().replace(/[?:]$/, '?');
    const answer = headingMatch[2].trim().replace(/\n+/g, ' ');
    if (question && answer) out.push({ question, answer });
  }
  return out;
}

const faqEntries = extractFaq(post.body_md);
const faqLd = faqEntries.length > 0
  ? {
      '@context': 'https://schema.org',
      '@type': 'FAQPage',
      mainEntity: faqEntries.map((f) => ({
        '@type': 'Question',
        name: f.question,
        acceptedAnswer: { '@type': 'Answer', text: f.answer },
      })),
    }
  : null;

// Article JSON-LD — gives Google the dateModified signal so freshness
// regenerations get picked up.
const publishedIso = post.published_at ? new Date(post.published_at * 1000).toISOString() : null;
const modifiedIso = new Date(post.generated_at * 1000).toISOString();
const articleLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.title,
  description: post.description,
  datePublished: publishedIso ?? modifiedIso,
  dateModified: modifiedIso,
  author: { '@type': 'Person', name: 'Lucas Leung' },
  publisher: {
    '@type': 'Organization',
    name: 'Lucas Eats Big',
    url: 'https://lucaseatsbig.com',
  },
  mainEntityOfPage: `https://lucaseatsbig.com/guides/${post.slug}`,
};

// Related guides — internal-link compounding. Wrap in try/catch so the
// page still renders if the related_posts table hasn't been migrated yet.
let relatedGuides: Awaited<ReturnType<typeof getRelatedPosts>> = [];
try {
  relatedGuides = await getRelatedPosts(env.DB, post.slug, 4);
} catch {
  relatedGuides = [];
}

// SEO image points at the existing /api/og endpoint when we have a featured
// restaurant — guarantees the consistent 1200×630 cover. Falls back to the
// raw hero source if no restaurant is set.
const seoImage = post.og_image_restaurant_id
  ? `/api/og/${
      featured.find((f) => f.id === post.og_image_restaurant_id)?.slug ?? ''
    }.jpg`
  : (heroSrc ?? undefined);

function formatDate(epoch: number | null): string | null {
  if (!epoch) return null;
  return new Date(epoch * 1000).toLocaleDateString('en-AU', {
    day: 'numeric', month: 'long', year: 'numeric',
  });
}

const updated = formatDate(post.published_at ?? post.generated_at);
---
<BaseLayout
  title={`${post.title} · Lucas Eats Big`}
  description={post.description}
  image={seoImage}
  imageAlt={post.title}
  type="article"
>
  <Masthead active="all" />

  <main class="guide">
    <div class="back-link"><a href="/guides">← All guides</a></div>

    {heroSrc && (
      <section class="hero">
        <img src={heroSrc} alt="" decoding="async" />
      </section>
    )}

    <header class="head">
      <p class="kicker">{post.kind.toUpperCase()} · GUIDE{updated && <> · UPDATED {updated.toUpperCase()}</>}</p>
      <h1>{post.title}</h1>
      <p class="lede">{post.description}</p>
    </header>

    <article class="prose" set:html={bodyHtml}></article>

    {orderedCards.length > 0 && (
      <section class="featured">
        <h2>Restaurants in this guide</h2>
        <div class="featured-list">
          {orderedCards.map((r) => (
            <HomeListCard restaurant={r} photosBase={photosBase} compact />
          ))}
        </div>
      </section>
    )}

    <RelatedGuides guides={relatedGuides} photosBase={photosBase} />
  </main>

  {itemListLd && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(itemListLd)}></script>
  )}
  {faqLd && (
    <script type="application/ld+json" is:inline set:html={JSON.stringify(faqLd)}></script>
  )}
  <script type="application/ld+json" is:inline set:html={JSON.stringify(articleLd)}></script>
</BaseLayout>

<style>
  .guide {
    max-width: 760px;
    margin: 0 auto;
    padding: 1.5rem 1.25rem 4rem;
  }
  .back-link { margin-bottom: 1rem; }
  .back-link a {
    font-family: var(--sans);
    color: var(--muted);
    text-decoration: none;
    font-size: 0.875rem;
  }
  .back-link a:hover { color: var(--ink); }

  .hero {
    aspect-ratio: 16 / 9;
    border-radius: 14px;
    overflow: hidden;
    background: var(--paper);
    margin-bottom: 1.5rem;
  }
  .hero img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .head { margin-bottom: 2rem; }
  .kicker {
    font-family: var(--sans);
    font-size: 0.6875rem;
    letter-spacing: 0.18em;
    color: var(--muted);
    font-weight: 600;
    margin: 0 0 1rem;
    text-transform: uppercase;
  }
  .kicker::before {
    content: '';
    display: inline-block;
    width: 32px;
    border-top: 2px solid var(--terracotta);
    vertical-align: middle;
    margin-right: 0.6rem;
  }
  .head h1 {
    font-family: var(--serif);
    font-size: clamp(2rem, 5vw, 3.25rem);
    font-weight: 500;
    line-height: 1.05;
    letter-spacing: -0.025em;
    color: var(--ink);
    margin: 0;
  }
  .lede {
    margin: 1rem 0 0;
    color: var(--muted);
    font-size: 1.0625rem;
    line-height: 1.55;
  }

  /* Markdown body — :global so the rules reach generated HTML inside .prose */
  .prose :global(h2) {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 2.25rem 0 0.75rem;
    letter-spacing: -0.015em;
  }
  .prose :global(h3) {
    font-family: var(--serif);
    font-size: 1.1875rem;
    font-weight: 500;
    color: var(--ink);
    margin: 1.75rem 0 0.5rem;
  }
  .prose :global(p) {
    font-family: var(--serif);
    color: var(--ink);
    line-height: 1.7;
    font-size: 1.0625rem;
    margin: 0 0 1rem;
  }
  .prose :global(ul),
  .prose :global(ol) {
    font-family: var(--serif);
    color: var(--ink);
    line-height: 1.7;
    font-size: 1.0625rem;
    padding-left: 1.4rem;
    margin: 0 0 1rem;
  }
  .prose :global(li) { margin-bottom: 0.4rem; }
  .prose :global(strong) { font-weight: 600; }
  .prose :global(a) {
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
  }
  .prose :global(a:hover) { background: rgba(184, 84, 58, 0.08); }
  .prose :global(blockquote) {
    border-left: 3px solid var(--terracotta);
    padding-left: 1rem;
    margin: 1rem 0;
    font-style: italic;
    color: var(--muted);
  }

  .featured { margin-top: 3rem; }
  .featured h2 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 1.25rem;
    letter-spacing: -0.015em;
  }
  .featured-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }
  @media (min-width: 720px) {
    .featured-list { grid-template-columns: 1fr 1fr; gap: 0.75rem; }
  }
</style>

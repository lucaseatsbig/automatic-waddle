---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import HomeListCard from '../components/HomeListCard.astro';
import HeroCard from '../components/HeroCard.astro';
import HomeHero from '../components/HomeHero.astro';
import { getFeaturedRecent, getWishlistPreview, searchRestaurants } from '../lib/db';
import { placePhotoUrl } from '../lib/places';

const [featuredPool, wishlistPool, allVisited] = await Promise.all([
  // 11 so the desktop grid can skip recentList[0] (already shown in HomeHero's
  // "this week's pick" callout) and still render 10 cards.
  getFeaturedRecent(env.DB, 11),
  getWishlistPreview(env.DB, 20),
  searchRestaurants(env.DB, { visited: 'yes' }),
]);

// Pick N items maximising variety on `key` — first pass takes one per unseen
// key, second pass fills remaining slots in original order.
function pickVariety<T>(pool: T[], n: number, key: (item: T) => string | null): T[] {
  const result: T[] = [];
  const seen = new Set<string>();
  for (const item of pool) {
    if (result.length >= n) break;
    const k = key(item);
    if (k && seen.has(k)) continue;
    result.push(item);
    if (k) seen.add(k);
  }
  for (const item of pool) {
    if (result.length >= n) break;
    if (!result.includes(item)) result.push(item);
  }
  return result;
}

// Promote a high-rated place to the spotlight slot (recentList[0] — mobile
// HeroCard and desktop HomeHero side-photo). Prefer the most-recent 9+; fall
// back to 8+. The rest stay in recency order.
function promoteSpotlight<T extends { avg_overall: number | null }>(pool: T[]): T[] {
  const idx = (() => {
    const nine = pool.findIndex((r) => r.avg_overall != null && r.avg_overall >= 9);
    if (nine >= 0) return nine;
    return pool.findIndex((r) => r.avg_overall != null && r.avg_overall >= 8);
  })();
  if (idx <= 0) return pool;
  return [pool[idx], ...pool.slice(0, idx), ...pool.slice(idx + 1)];
}

const recentList = promoteSpotlight(featuredPool);
const wishlist = pickVariety(wishlistPool, 8, (w) => w.cuisine);

const visitedTotal = allVisited.length;
const photosBase = env.PUBLIC_PHOTOS_URL ?? '';

// --- Stats strip data for the desktop hero ---
const currentYear = new Date().getFullYear();
const yearVisits = allVisited.filter(
  (r) => r.latest_visit_date && new Date(r.latest_visit_date).getFullYear() === currentYear
).length;
const distinctCuisines = new Set(
  allVisited.map((r) => r.cuisine).filter((c): c is string => !!c)
).size;
const latestDate = allVisited
  .map((r) => r.latest_visit_date)
  .filter((d): d is string => !!d)
  .sort()
  .reverse()[0];
function sinceLabel(iso: string | undefined): string {
  if (!iso) return '–';
  const days = Math.floor((Date.now() - new Date(iso).getTime()) / (1000 * 60 * 60 * 24));
  if (days < 1) return 'today';
  if (days < 7) return `${days}d`;
  if (days < 30) return `${Math.floor(days / 7)}w`;
  if (days < 365) return `${Math.floor(days / 30)}mo`;
  return `${Math.floor(days / 365)}y`;
}
const heroStats = [
  { number: String(visitedTotal), label: 'places' },
  { number: String(yearVisits), label: `visited '${String(currentYear).slice(-2)}` },
  { number: String(distinctCuisines), label: 'cuisines' },
  // "Since last visit" wraps to a second row on narrow screens — hide it there.
  { number: sinceLabel(latestDate), label: 'since last visit', hideOnMobile: true },
];

// --- "This week's pick" side photo (most-recent visited with a usable photo) ---
const pickRestaurant = recentList[0] ?? null;
const pickPhotoUrl = pickRestaurant
  ? (pickRestaurant.cover_r2_key && photosBase
      ? `${photosBase}/${pickRestaurant.cover_r2_key}`
      : pickRestaurant.hero_photo_name
        ? placePhotoUrl(pickRestaurant.hero_photo_name, 800)
        : null)
  : null;
const heroPick = pickRestaurant
  ? {
      name: pickRestaurant.name,
      location: pickRestaurant.location,
      rating: pickRestaurant.avg_overall,
      photoUrl: pickPhotoUrl,
      href: `/restaurants/${pickRestaurant.slug}`,
    }
  : undefined;
---
<BaseLayout title="Lucas Eats Big · everywhere I've eaten in Sydney">
  <Masthead active="home" />

  <HomeHero kicker="SYDNEY · UPDATED WEEKLY" igHandle="lucaseatsbig" stats={heroStats} pick={heroPick}>
    <Fragment slot="title">
      Hi, I'm Lucas.<br />
      This is <em>everywhere I've eaten</em> and my honest thoughts.
    </Fragment>
    <Fragment slot="cta">
      <a href="/all" class="hero-cta">Find a restaurant here <span class="arrow" aria-hidden="true">→</span></a>
    </Fragment>
  </HomeHero>

  {/* recentList[0] is the "this week's pick" rendered in HomeHero above.
      recentList[1] becomes the section's HeroCard so the visual lead-in
      isn't a duplicate of the spotlight. The compact list starts at [2]. */}
  {recentList.length > 1 && (
    <section class="featured-section">
      <header class="section-head">
        <h2>Best places I've been to lately</h2>
        <span class="section-meta">{visitedTotal} places · <a href="/all">see the list</a></span>
      </header>

      {/* Mobile (<900px): HomeHero's side-photo "pick" doesn't render at this
          width, so recentList[0] becomes the HeroCard here — the most
          prominent slot. The compact list starts at [1]. */}
      <div class="layout-mobile">
        {recentList[0] && (
          <div class="recent-hero">
            <HeroCard restaurant={recentList[0]} photosBase={photosBase} />
          </div>
        )}
        {recentList.length > 1 && (
          <div class="recent-list">
            {recentList.slice(1).map((r) => (
              <HomeListCard restaurant={r} photosBase={photosBase} compact />
            ))}
          </div>
        )}
      </div>

      {/* Desktop (≥900px): no big hero card here — HomeHero's side-photo
          callout already serves as the spotlight. We skip recentList[0]
          (the spotlight) so the grid stays unique, and the pool is 11 so
          the resulting 2-col grid still has 10 cards (5 rows × 2 cols). */}
      <div class="layout-desktop">
        <div class="recent-list">
          {recentList.slice(1).map((r) => (
            <HomeListCard restaurant={r} photosBase={photosBase} compact />
          ))}
        </div>
      </div>

      {visitedTotal > recentList.length && (
        <p class="see-more"><a href="/all?visited=yes">See all {visitedTotal} visited →</a></p>
      )}
    </section>
  )}

  {wishlist.length > 0 && (
    <section class="wishlist-section">
      <header class="section-head">
        <h2>On the list</h2>
        <span class="section-meta">places I haven't been yet · <a href="/all?visited=no">see all</a></span>
      </header>
      <div class="wishlist-list">
        {wishlist.map((w) => (
          <HomeListCard restaurant={w} photosBase={photosBase} compact />
        ))}
      </div>
    </section>
  )}

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Lucas Eats Big · A personal list. Bias included.</p>
  </footer>
</BaseLayout>

<style>
  @media (max-width: 600px) {
    section[class$='-section'] { padding: 2rem 1rem 1rem; }
  }

  /* Sections */
  section[class$='-section'] {
    max-width: 1180px;
    margin: 0 auto;
    padding: 2.75rem 1.5rem 1rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .section-head h2 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.625rem;
    color: var(--ink);
    margin: 0;
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  .section-meta {
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .section-meta a {
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
  }
  .section-meta a:hover { background: rgba(184, 84, 58, 0.08); }

  /* Two-layout swap at 900px. Below: recentList[0] is the HeroCard, list
     starts at [1]. Above: HomeHero's side photo carries [0], section HeroCard
     is [1], list starts at [2]. Toggling whole subtrees avoids juggling
     conditional indices and keeps both layouts dead simple to reason about. */
  .layout-desktop { display: none; }
  @media (min-width: 900px) {
    .layout-mobile { display: none; }
    .layout-desktop { display: block; }
  }

  /* Recent list */
  .recent-hero { margin-bottom: 0.875rem; }
  .recent-list,
  .wishlist-list {
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.6rem;
  }
  /* Two-column grid on desktop matches the editorial cover layout. The hero
     card stays full-width above the grid (it lives in .recent-hero, not in
     this grid container). */
  @media (min-width: 900px) {
    .recent-list,
    .wishlist-list {
      grid-template-columns: 1fr 1fr;
      gap: 0.75rem 0.875rem;
    }
  }
  .see-more {
    text-align: center;
    margin: 1.25rem 0 0;
    font-size: 0.875rem;
  }
  .see-more a {
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
  }

  /* Footer */
  .site-footer {
    max-width: 1180px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2.5rem;
    border-top: 1px solid var(--rule);
    margin-top: 3rem;
  }
  .site-footer p {
    color: var(--muted);
    font-size: 0.8125rem;
    margin: 0;
    text-align: center;
  }
</style>

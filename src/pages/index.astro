---
import { env } from 'cloudflare:workers';
import BaseLayout from '../layouts/BaseLayout.astro';
import Masthead from '../components/Masthead.astro';
import HomeListCard from '../components/HomeListCard.astro';
import HeroCard from '../components/HeroCard.astro';
import PageHead from '../components/PageHead.astro';
import { getFeaturedRecent, getWishlistPreview, searchRestaurants } from '../lib/db';

const [featuredPool, wishlistPool, allVisited] = await Promise.all([
  getFeaturedRecent(env.DB, 10),
  getWishlistPreview(env.DB, 20),
  searchRestaurants(env.DB, { visited: 'yes' }),
]);

// Pick N items maximising variety on `key` — first pass takes one per unseen
// key, second pass fills remaining slots in original order.
function pickVariety<T>(pool: T[], n: number, key: (item: T) => string | null): T[] {
  const result: T[] = [];
  const seen = new Set<string>();
  for (const item of pool) {
    if (result.length >= n) break;
    const k = key(item);
    if (k && seen.has(k)) continue;
    result.push(item);
    if (k) seen.add(k);
  }
  for (const item of pool) {
    if (result.length >= n) break;
    if (!result.includes(item)) result.push(item);
  }
  return result;
}

const recentList = featuredPool.slice(0, 10);
const wishlist = pickVariety(wishlistPool, 8, (w) => w.cuisine);

const visitedTotal = allVisited.length;
const photosBase = env.PUBLIC_PHOTOS_URL ?? '';
---
<BaseLayout title="Lucas Eats Big · everywhere I've eaten in Sydney">
  <Masthead active="home" />

  <PageHead kicker="SYDNEY · UPDATED WEEKLY">
    <Fragment slot="title">
      Hi, I'm Lucas.<br />
      This is <em>everywhere I've eaten</em><br />
      and what I think of it.
    </Fragment>
    <Fragment slot="lede">
      A running list of Sydney spots I've been to, ranked honestly. Friends keep asking me where to eat, so I made this for them.
      Browse by neighbourhood, vibe, or rating, or jump to <a href="/all">the full database</a>.
    </Fragment>
  </PageHead>

  {recentList.length > 0 && (
    <section class="featured-section">
      <header class="section-head">
        <h2>Best places I've been to lately</h2>
        <span class="section-meta">{visitedTotal} places · <a href="/all">see the list</a></span>
      </header>
      <div class="recent-list">
        {recentList[0] && <HeroCard restaurant={recentList[0]} photosBase={photosBase} />}
        {recentList.slice(1).map((r) => (
          <HomeListCard restaurant={r} photosBase={photosBase} />
        ))}
      </div>
      {visitedTotal > recentList.length && (
        <p class="see-more"><a href="/all?visited=yes">See all {visitedTotal} visited →</a></p>
      )}
    </section>
  )}

  {wishlist.length > 0 && (
    <section class="wishlist-section">
      <header class="section-head">
        <h2>On the list</h2>
        <span class="section-meta">places I haven't been yet · <a href="/all?visited=no">see all</a></span>
      </header>
      <div class="wishlist-list">
        {wishlist.map((w) => (
          <HomeListCard restaurant={w} photosBase={photosBase} />
        ))}
      </div>
    </section>
  )}

  <footer class="site-footer">
    <p>© {new Date().getFullYear()} Lucas Eats Big · A personal list. Bias included.</p>
  </footer>
</BaseLayout>

<style>
  @media (max-width: 600px) {
    section[class$='-section'] { padding: 2rem 1rem 1rem; }
  }

  /* Sections */
  section[class$='-section'] {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 1.5rem 1rem;
  }
  .section-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    margin-bottom: 1.5rem;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .section-head h2 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.625rem;
    color: var(--ink);
    margin: 0;
    font-weight: 500;
    letter-spacing: -0.015em;
  }
  .section-meta {
    color: var(--muted);
    font-size: 0.8125rem;
  }
  .section-meta a {
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
  }
  .section-meta a:hover { background: rgba(184, 84, 58, 0.08); }

  /* Recent list */
  .recent-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }
  .see-more {
    text-align: center;
    margin: 1.25rem 0 0;
    font-size: 0.875rem;
  }
  .see-more a {
    color: var(--terracotta);
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
  }

  /* Wishlist */
  .wishlist-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  /* Footer */
  .site-footer {
    max-width: 1280px;
    margin: 0 auto;
    padding: 4rem 1.5rem 2.5rem;
    border-top: 1px solid var(--rule);
    margin-top: 3rem;
  }
  .site-footer p {
    color: var(--muted);
    font-size: 0.8125rem;
    margin: 0;
    text-align: center;
  }
</style>

---
import BaseLayout from '../../layouts/BaseLayout.astro';
const nextTarget = Astro.url.searchParams.get('next') || '/admin';
const hasError = Astro.url.searchParams.get('error') === '1';
---
<BaseLayout title="Admin — Lucas Eats Big">
  <main class="login">
    <h1>Admin</h1>
    <form method="post" action="/api/admin/login" class="form">
      <input type="hidden" name="next" value={nextTarget} />
      <label>
        <span>Password</span>
        <input
          type="password"
          name="password"
          required
          autocomplete="current-password"
          autofocus
        />
      </label>
      <button type="submit">Sign in</button>
      {hasError && <p class="error">Wrong password.</p>}
    </form>
  </main>
</BaseLayout>

<style>
  .login {
    max-width: 360px;
    margin: 5rem auto;
    padding: 0 1.5rem;
  }
  h1 {
    margin: 0 0 2rem;
    text-align: center;
    letter-spacing: -0.02em;
  }
  .form {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  label {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    font-size: 0.85rem;
    color: #666;
  }
  input {
    padding: 0.75rem 0.9rem;
    border: 1px solid #d8d3c4;
    border-radius: 8px;
    font-size: 1rem;
    background: white;
  }
  button {
    padding: 0.8rem;
    background: #2a2a2a;
    color: white;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    font-size: 1rem;
  }
  button:hover { background: #000; }
  .error {
    color: #c53030;
    text-align: center;
    margin: 0;
    font-size: 0.9rem;
  }
</style>

---
import type { Location, RestaurantEditData, Tag } from '../../lib/types';

interface Props {
  restaurant?: RestaurantEditData;
  locations: Location[];
  tags: Tag[];
  cuisines: string[];
  action: string;
  googleMapsKey?: string;
}
const { restaurant, locations, tags, cuisines, action, googleMapsKey = '' } = Astro.props;
const r = restaurant;
const hasMapsKey = googleMapsKey.length > 0;
const tagIds = new Set(r?.tag_ids ?? []);
const vibes = tags.filter((t) => t.category === 'vibe');
const dietary = tags.filter((t) => t.category === 'dietary');
const other = tags.filter((t) => t.category === 'other');
const currentLocationName = r?.location_id
  ? locations.find((l) => l.id === r.location_id)?.name ?? ''
  : '';
---
<form method="post" action={action} class="rest-form" id="rest-form">
  <div class="grid">
    <label class="field span-2">
      <span>Name *</span>
      <input type="text" name="name" id="rf-name" required value={r?.name ?? ''} autocomplete="off" />
      {hasMapsKey && (
        <p class="hint">Type to search Google Maps — picking a result fills any blank fields below.</p>
      )}
    </label>

    <label class="field">
      <span>Slug</span>
      <input
        type="text"
        name="slug"
        value={r?.slug ?? ''}
        placeholder="auto-generated from name"
      />
    </label>

    <label class="field">
      <span>Cuisine</span>
      <input
        type="text"
        name="cuisine"
        value={(r?.cuisines && r.cuisines.length > 0 ? r.cuisines.join(', ') : (r?.cuisine ?? ''))}
        placeholder="e.g. American, Japanese"
        list="cuisine-list"
        autocomplete="off"
      />
      <datalist id="cuisine-list">
        {cuisines.map((c) => <option value={c}></option>)}
      </datalist>
      <p class="hint">Multiple cuisines? Separate with commas — the first one shows on cards.</p>
    </label>

    <label class="field">
      <span>Suburb</span>
      <input
        type="text"
        name="location_name"
        id="rf-location"
        value={currentLocationName}
        placeholder="Start typing a Sydney suburb…"
        list="location-list"
        autocomplete="off"
      />
      <datalist id="location-list">
        {locations.map((l) => <option value={l.name}></option>)}
      </datalist>
    </label>

    <label class="field">
      <span>Price</span>
      <select name="price_tier">
        <option value="">—</option>
        {[1, 2, 3, 4, 5].map((p) => (
          <option value={p} selected={r?.price_tier === p}>
            {'$'.repeat(p)} ({['0–20', '20–50', '50–100', '100–200', '200+'][p - 1]})
          </option>
        ))}
      </select>
    </label>

    <label class="field span-2">
      <span>Address</span>
      <input type="text" name="address" id="rf-address" value={r?.address ?? ''} />
    </label>

    <label class="field">
      <span>Website</span>
      <input type="url" name="website_url" id="rf-website" value={r?.website_url ?? ''} placeholder="https://…" />
    </label>

    <label class="field">
      <span>Google Maps link</span>
      <input type="url" name="maps_url" id="rf-maps-url" value={r?.maps_url ?? ''} placeholder="https://www.google.com/maps/…" />
    </label>

    <input type="hidden" name="place_id" id="rf-place-id" value={r?.place_id ?? ''} />
    <input type="hidden" name="lat" id="rf-lat" value={r?.lat ?? ''} />
    <input type="hidden" name="lng" id="rf-lng" value={r?.lng ?? ''} />

    <label class="field span-2">
      <span>Wishlist note <em>(only shown if no review)</em></span>
      <textarea name="wishlist_note" placeholder="What you've heard or want to try">{r?.wishlist_note ?? ''}</textarea>
    </label>
  </div>

  <fieldset class="tags-group">
    <legend>Vibes</legend>
    <div class="chips">
      {vibes.map((t) => (
        <label class={`chip ${tagIds.has(t.id) ? 'on' : ''}`}>
          <input type="checkbox" name="tag_ids" value={t.id} checked={tagIds.has(t.id)} />
          {t.label}
        </label>
      ))}
    </div>
  </fieldset>

  <fieldset class="tags-group">
    <legend>Dietary</legend>
    <div class="chips">
      {dietary.map((t) => (
        <label class={`chip ${tagIds.has(t.id) ? 'on' : ''}`}>
          <input type="checkbox" name="tag_ids" value={t.id} checked={tagIds.has(t.id)} />
          {t.label}
        </label>
      ))}
    </div>
  </fieldset>

  {other.length > 0 && (
    <fieldset class="tags-group">
      <legend>Other</legend>
      <div class="chips">
        {other.map((t) => (
          <label class={`chip ${tagIds.has(t.id) ? 'on' : ''}`}>
            <input type="checkbox" name="tag_ids" value={t.id} checked={tagIds.has(t.id)} />
            {t.label}
          </label>
        ))}
      </div>
    </fieldset>
  )}

  <div class="actions">
    <a href="/admin" class="btn">Cancel</a>
    <button type="submit" class="btn primary">{r ? 'Save changes' : 'Create restaurant'}</button>
  </div>
</form>

<script>
  document.querySelectorAll<HTMLInputElement>('.rest-form .chip input').forEach((el) => {
    el.addEventListener('change', () => {
      el.closest('.chip')?.classList.toggle('on', el.checked);
    });
  });
</script>

<script is:inline define:vars={{ googleMapsKey, hasMapsKey }}>
  // Google Places autocomplete on the Name input (edit form).
  // Picking a result fills any blank fields and updates the canonical
  // place identifiers (place_id, lat/lng) — never overwrites data already there.
  if (hasMapsKey) {
    const nameInput = document.getElementById('rf-name');
    if (nameInput) {
      const script = document.createElement('script');
      script.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(googleMapsKey)}&libraries=places&v=weekly&loading=async&callback=__rfInitPlaces`;
      script.async = true;
      window.__rfInitPlaces = function () {
        if (!window.google?.maps?.places) return;
        const ac = new google.maps.places.Autocomplete(nameInput, {
          fields: ['name', 'formatted_address', 'website', 'address_components', 'place_id', 'geometry'],
          types: ['establishment'],
        });
        ac.addListener('place_changed', () => {
          const place = ac.getPlace();
          // Only fill blank fields. Always update the canonical identifiers.
          const fillIfBlank = (id, val) => {
            const el = document.getElementById(id);
            if (el && val != null && !el.value) el.value = val;
          };
          const setAlways = (id, val) => {
            const el = document.getElementById(id);
            if (el && val != null) el.value = val;
          };

          if (place.formatted_address) fillIfBlank('rf-address', place.formatted_address);
          if (place.website)           fillIfBlank('rf-website', place.website);

          const comps = place.address_components || [];
          const pickComp = (types) =>
            comps.find((c) => types.some((t) => c.types?.includes(t)))?.long_name;
          const suburb = pickComp(['locality']) || pickComp(['sublocality', 'sublocality_level_1']) || pickComp(['postal_town']);
          if (suburb) fillIfBlank('rf-location', suburb);

          if (place.place_id) {
            setAlways('rf-place-id', place.place_id);
            const mapsEl = document.getElementById('rf-maps-url');
            if (mapsEl && !mapsEl.value) {
              mapsEl.value = `https://www.google.com/maps/place/?q=place_id:${place.place_id}`;
            }
          }
          const loc = place.geometry?.location;
          if (loc) {
            setAlways('rf-lat', String(loc.lat()));
            setAlways('rf-lng', String(loc.lng()));
          }
        });

        const style = document.createElement('style');
        style.textContent = '.pac-container { z-index: 10000; }';
        document.head.appendChild(style);
      };
      document.head.appendChild(script);
    }
  }
</script>

<style>
  .rest-form {
    background: white;
    border-radius: 12px;
    padding: 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
    box-shadow: 0 1px 2px rgba(0, 0, 0, 0.05);
  }
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.9rem;
  }
  .span-2 { grid-column: 1 / -1; }
  @media (max-width: 600px) { .grid { grid-template-columns: 1fr; } .span-2 { grid-column: auto; } }

  em { color: #999; font-style: normal; font-size: 0.75rem; }

  .tags-group { border: none; padding: 0; margin: 0; }
  .tags-group legend {
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #8a7f6a;
    margin-bottom: 0.4rem;
    padding: 0;
  }
  .chips { display: flex; flex-wrap: wrap; gap: 0.35rem; }
  .chip {
    display: inline-flex;
    padding: 0.35rem 0.8rem;
    border: 1px solid #d8d3c4;
    border-radius: 999px;
    background: white;
    cursor: pointer;
    font-size: 0.85rem;
    user-select: none;
  }
  .chip.on { background: #2a2a2a; color: white; border-color: #2a2a2a; }
  .chip input { display: none; }

  .actions {
    display: flex;
    gap: 0.75rem;
    justify-content: flex-end;
    border-top: 1px solid #eee;
    padding-top: 1rem;
  }
</style>

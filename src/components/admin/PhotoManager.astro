---
import type { ReviewEditData } from '../../lib/types';

interface Props {
  review: ReviewEditData;
  photosBase: string;
}
const { review, photosBase } = Astro.props;
const hasBase = photosBase.length > 0;
---
<section class="photo-manager" data-review-id={review.id}>
  {!hasBase && (
    <p class="warn">
      <strong>Heads up:</strong> <code>PUBLIC_PHOTOS_URL</code> isn't set, so uploaded photos won't be
      viewable until you add the env var in the Worker settings and redeploy. Uploads still work.
    </p>
  )}

  <div class="upload-row">
    <label class="upload-btn">
      <input
        type="file"
        id="photo-input"
        accept="image/jpeg,image/png,image/webp,image/heic,image/heif,image/*"
        multiple
      />
      <span class="btn primary">📷 Add from library</span>
    </label>
    <label class="upload-btn">
      <input
        type="file"
        id="photo-input-camera"
        accept="image/*"
        capture="environment"
      />
      <span class="btn">📸 Take a photo</span>
    </label>
  </div>

  <ul class="queue" id="upload-queue"></ul>

  <ul class="photos" id="photo-list">
    {review.photos.map((p) => (
      <li class="photo" data-id={p.id}>
        <div class="img-wrap">
          {hasBase
            ? <img src={`${photosBase}/${p.r2_key}`} alt={p.alt ?? ''} loading="lazy" />
            : <div class="placeholder">No preview</div>}
          {p.is_cover && <span class="cover-badge">Cover</span>}
        </div>
        <div class="photo-actions">
          {!p.is_cover && (
            <button type="button" class="btn set-cover" data-action="cover">Set cover</button>
          )}
          <button type="button" class="btn danger" data-action="delete">Delete</button>
        </div>
      </li>
    ))}
  </ul>

  {review.photos.length === 0 && (
    <p class="empty" id="empty-msg">No photos yet. Tap "Add photos" above.</p>
  )}
</section>

<script is:inline define:vars={{ reviewId: review.id, photosBase: photosBase }}>
  const MAX_DIM = 2000;
  const JPEG_QUALITY = 0.85;

  const inputs = [
    document.getElementById('photo-input'),
    document.getElementById('photo-input-camera'),
  ].filter(Boolean);
  const queue = document.getElementById('upload-queue');
  const list = document.getElementById('photo-list');
  const emptyMsg = document.getElementById('empty-msg');

  for (const input of inputs) {
    input.addEventListener('change', async (e) => {
      const files = Array.from(e.target.files || []);
      if (files.length === 0) return;
      e.target.value = '';
      for (const file of files) {
        await handleOne(file);
      }
    });
  }

  async function handleOne(file) {
    const row = document.createElement('li');
    row.className = 'queue-row';
    row.innerHTML = `<span class="name">${file.name}</span><span class="status">Resizing…</span>`;
    queue?.appendChild(row);

    try {
      // Try client-side resize to JPEG. If that fails (e.g. HEIC the browser can't decode),
      // fall back to uploading the raw file.
      let blob = file;
      let filename = file.name || 'photo';
      let width = null;
      let height = null;
      try {
        const resized = await resizeToJpeg(file, MAX_DIM, JPEG_QUALITY);
        blob = resized.blob;
        filename = 'photo.jpg';
        width = resized.width;
        height = resized.height;
      } catch (resizeErr) {
        console.warn('Resize failed, uploading raw:', resizeErr);
      }

      row.querySelector('.status').textContent = 'Uploading…';
      const fd = new FormData();
      fd.append('review_id', String(reviewId));
      fd.append('file', blob, filename);
      if (width != null) fd.append('width', String(width));
      if (height != null) fd.append('height', String(height));
      if (list && list.children.length === 0) fd.append('make_cover', '1');

      const res = await fetch('/api/admin/photos', { method: 'POST', body: fd });
      if (!res.ok) {
        const body = await res.text();
        throw new Error(`Upload ${res.status}: ${body}`);
      }
      const photo = await res.json();

      row.remove();
      appendPhoto(photo);
      emptyMsg?.remove();
    } catch (err) {
      console.error(err);
      row.querySelector('.status').textContent = 'Failed — see console';
      row.classList.add('error');
    }
  }

  function appendPhoto(p) {
    if (!list) return;
    const li = document.createElement('li');
    li.className = 'photo';
    li.dataset.id = p.id;
    const src = photosBase ? `${photosBase}/${p.r2_key}` : '';
    li.innerHTML = `
      <div class="img-wrap">
        ${src ? `<img src="${src}" alt="" loading="lazy">` : '<div class="placeholder">No preview</div>'}
        ${p.is_cover ? '<span class="cover-badge">Cover</span>' : ''}
      </div>
      <div class="photo-actions">
        ${!p.is_cover ? '<button type="button" class="btn set-cover" data-action="cover">Set cover</button>' : ''}
        <button type="button" class="btn danger" data-action="delete">Delete</button>
      </div>
    `;
    list.appendChild(li);
  }

  list?.addEventListener('click', async (e) => {
    const btn = e.target.closest('button[data-action]');
    if (!btn) return;
    const li = btn.closest('.photo');
    if (!li) return;
    const id = li.dataset.id;
    const action = btn.dataset.action;

    if (action === 'delete') {
      if (!confirm('Delete this photo?')) return;
      btn.disabled = true;
      const res = await fetch(`/api/admin/photos/${id}`, { method: 'DELETE' });
      if (res.ok) li.remove();
      else { btn.disabled = false; alert('Delete failed'); }
    } else if (action === 'cover') {
      btn.disabled = true;
      const fd = new FormData();
      fd.append('action', 'cover');
      const res = await fetch(`/api/admin/photos/${id}`, { method: 'POST', body: fd });
      if (res.ok) window.location.reload();
      else { btn.disabled = false; alert('Failed to set cover'); }
    }
  });

  async function resizeToJpeg(file, maxDim, quality) {
    const img = await loadImageFromFile(file);
    const scale = Math.min(maxDim / img.width, maxDim / img.height, 1);
    const w = Math.round(img.width * scale);
    const h = Math.round(img.height * scale);
    const canvas = document.createElement('canvas');
    canvas.width = w;
    canvas.height = h;
    const ctx = canvas.getContext('2d');
    ctx.drawImage(img, 0, 0, w, h);
    const blob = await new Promise((res) => canvas.toBlob(res, 'image/jpeg', quality));
    if (!blob) throw new Error('Could not encode image');
    return { blob, width: w, height: h };
  }

  function loadImageFromFile(file) {
    return new Promise((resolve, reject) => {
      const url = URL.createObjectURL(file);
      const img = new Image();
      img.onload = () => { URL.revokeObjectURL(url); resolve(img); };
      img.onerror = () => { URL.revokeObjectURL(url); reject(new Error('Bad image')); };
      img.src = url;
    });
  }
</script>

<style>
  .photo-manager { display: flex; flex-direction: column; gap: 1rem; }
  .warn {
    background: #fff8e1; border: 1px solid #f0d580; color: #7a5a0a;
    padding: 0.6rem 0.85rem; border-radius: 8px; margin: 0; font-size: 0.85rem;
  }
  .warn code { background: rgba(0,0,0,0.06); padding: 0 0.25rem; border-radius: 3px; }

  .upload-row { display: flex; flex-wrap: wrap; gap: 0.5rem; }
  .upload-btn { display: inline-block; cursor: pointer; }
  .upload-btn input[type='file'] {
    position: absolute;
    width: 1px; height: 1px;
    padding: 0; margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }
  .upload-btn .btn { cursor: pointer; }

  .queue { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 0.3rem; }
  .queue-row {
    display: flex; justify-content: space-between; align-items: center;
    padding: 0.5rem 0.8rem; background: #f5f3ee; border-radius: 8px; font-size: 0.85rem;
  }
  .queue-row .name { color: #555; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; }
  .queue-row .status { color: #888; font-size: 0.8rem; }
  .queue-row.error .status { color: #c53030; }

  .photos {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(170px, 1fr));
    gap: 0.75rem;
  }
  .photo { background: white; border-radius: 10px; padding: 0.5rem; box-shadow: 0 1px 2px rgba(0,0,0,0.04); }
  .img-wrap {
    position: relative; aspect-ratio: 1 / 1; background: #efece4;
    border-radius: 6px; overflow: hidden; margin-bottom: 0.5rem;
  }
  .img-wrap img { width: 100%; height: 100%; object-fit: cover; }
  .placeholder {
    display: flex; align-items: center; justify-content: center; height: 100%;
    color: #a8a08a; font-size: 0.75rem;
  }
  .cover-badge {
    position: absolute; top: 0.35rem; left: 0.35rem;
    background: rgba(0,0,0,0.8); color: white;
    padding: 0.15rem 0.4rem; border-radius: 999px;
    font-size: 0.65rem; text-transform: uppercase; letter-spacing: 0.05em;
  }
  .photo-actions { display: flex; gap: 0.3rem; }
  .photo-actions .btn { padding: 0.35rem 0.6rem; font-size: 0.8rem; flex: 1; justify-content: center; }
  .empty { color: #888; font-size: 0.9rem; margin: 0; }
</style>

---
import type { Filters, Location, Tag } from '../lib/types';
import { REGIONS, type Region } from '../lib/regions';

interface Props {
  filters: Filters;
  locations: Location[];
  regions?: Region[];
  tags: Tag[];
  cuisines: string[];
  count?: number;
  /**
   * Current view mode on /all. Threaded through the sheet's forms and
   * Reset/Clear-all links so map view survives filter changes.
   */
  view?: 'list' | 'map';
}
const { filters, locations, regions = REGIONS, tags, cuisines, count = 0, view = 'list' } = Astro.props;
const clearAllHref = view === 'map' ? '/all?view=map' : '/all';

const vibes = tags.filter((t) => t.category === 'vibe');
const TOP_RATED_THRESHOLD = 7;
const topRated = filters.minRating != null && filters.minRating >= TOP_RATED_THRESHOLD;

// Mirrors the canonical ranges in src/components/admin/RestaurantForm.astro
// and UnifiedEntryForm.astro — keep these in sync with the admin entry form.
const PRICE_TIERS: { tier: number; symbol: string; range: string }[] = [
  { tier: 1, symbol: '$',     range: '$0–20'   },
  { tier: 2, symbol: '$$',    range: '$20–50'  },
  { tier: 3, symbol: '$$$',   range: '$50–100' },
  { tier: 4, symbol: '$$$$',  range: '$100–200'},
  { tier: 5, symbol: '$$$$$', range: '$200+'   },
];

const sort = filters.sort ?? 'name';

const selectedCuisines = filters.cuisines ?? [];
const selectedRegions = filters.regions ?? [];
const selectedSuburbs = filters.locations ?? [];

const SORT_OPTIONS = [
  { value: 'name',   label: 'A–Z'    },
  { value: 'rating', label: 'Best'   },
  { value: 'recent', label: 'Recent' },
] as const;

// For the visible sort label outside the sheet, use the longer human-readable
// labels so the row reads naturally ("Sort: Best first ↕").
const SORT_LONG_LABELS: Record<string, string> = {
  rating: 'Best first',
  recent: 'Recently visited',
  name: 'A to Z',
};
const sortCycle = ['name', 'rating', 'recent'] as const;
const sortIdx = sortCycle.indexOf(sort as typeof sortCycle[number]);
const nextSort = sortCycle[(sortIdx + 1) % sortCycle.length];

function urlWithSort(value: string): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  if (value === 'name') params.delete('sort');
  else params.set('sort', value);
  const qs = params.toString();
  return qs ? `/all?${qs}` : '/all';
}
const nextSortHref = urlWithSort(nextSort);

const isOn = (arr: string[] | undefined, v: string) => (arr ?? []).includes(v);
const isPriceOn = (n: number) => (filters.price ?? []).includes(n);

let activeCount = 0;
activeCount += selectedCuisines.length;
activeCount += selectedRegions.length;
activeCount += selectedSuburbs.length;
if (topRated) activeCount++;
if (filters.visited) activeCount++;
if (filters.price && filters.price.length) activeCount += filters.price.length;
if (filters.vibes && filters.vibes.length) activeCount += filters.vibes.length;
if (sort !== 'name') activeCount++;

// Build "applied filter" chips that link to a URL with that filter removed.
function urlWithout(name: string, value?: string): string {
  const params = new URLSearchParams(Astro.url.searchParams);
  if (value !== undefined) {
    const all = params.getAll(name);
    params.delete(name);
    for (const v of all) if (v !== value) params.append(name, v);
  } else {
    params.delete(name);
  }
  const qs = params.toString();
  return qs ? `/all?${qs}` : '/all';
}

interface ActiveChip { key: string; label: string; href: string; }
const activeChips: ActiveChip[] = [];
for (const c of selectedCuisines) {
  activeChips.push({ key: `cu-${c}`, label: c, href: urlWithout('cuisine', c) });
}
for (const slug of selectedRegions) {
  const rname = REGIONS.find((r) => r.slug === slug)?.name ?? slug;
  activeChips.push({ key: `rg-${slug}`, label: rname, href: urlWithout('location', `region:${slug}`) });
}
for (const slug of selectedSuburbs) {
  const lname = locations.find((l) => l.slug === slug)?.name ?? slug;
  activeChips.push({ key: `su-${slug}`, label: lname, href: urlWithout('location', slug) });
}
if (topRated) {
  activeChips.push({ key: 'tr', label: `Top rated (${TOP_RATED_THRESHOLD}+)`, href: urlWithout('minRating') });
}
if (filters.visited === 'yes') {
  activeChips.push({ key: 'vs', label: 'Visited', href: urlWithout('visited') });
} else if (filters.visited === 'no') {
  activeChips.push({ key: 'vs', label: 'On the list', href: urlWithout('visited') });
}
for (const tier of filters.price ?? []) {
  const p = PRICE_TIERS.find((x) => x.tier === tier);
  if (p) activeChips.push({ key: `p-${tier}`, label: p.symbol, href: urlWithout('price', String(tier)) });
}
for (const slug of filters.vibes ?? []) {
  const v = vibes.find((x) => x.slug === slug);
  if (v) activeChips.push({ key: `v-${slug}`, label: v.label, href: urlWithout('vibes', slug) });
}
---

<div class="mfs-bar">
  {/* Mobile-only "tap to filter" nudge. Positioned absolutely so it floats
      in the page-head's existing bottom padding and consumes no layout space —
      the restaurant list below stays as visible as it would without the CTA. */}
  {activeCount === 0 && !filters.q && (
    <div class="mfs-trigger-cta" aria-hidden="true">
      <span class="mfs-trigger-cta-label">Tap to filter</span>
      <svg class="mfs-trigger-cta-arrow" width="44" height="32" viewBox="0 0 44 32" fill="none" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round">
        <path d="M3 5 C 12 7, 22 12, 28 16 S 36 26, 38 30" />
        <path d="M38 24 L 38 30 L 32 28" />
      </svg>
    </div>
  )}

  {/*
    Search form. Carries the existing filter selections as hidden inputs so a
    search submission narrows the current filtered set instead of replacing it.
  */}
  <form class="mfs-search-row" method="get" action="/all" role="search">
    {selectedCuisines.map((c) => <input type="hidden" name="cuisine" value={c} />)}
    {selectedRegions.map((r) => <input type="hidden" name="location" value={`region:${r}`} />)}
    {selectedSuburbs.map((s) => <input type="hidden" name="location" value={s} />)}
    {(filters.price ?? []).map((p) => <input type="hidden" name="price" value={p} />)}
    {(filters.vibes ?? []).map((v) => <input type="hidden" name="vibes" value={v} />)}
    {topRated && <input type="hidden" name="minRating" value={String(TOP_RATED_THRESHOLD)} />}
    {sort !== 'name' && <input type="hidden" name="sort" value={sort} />}
    {/* Preserve map/list view across search submission. */}
    {view === 'map' && <input type="hidden" name="view" value="map" />}

    <div class="mfs-search-input-wrap">
      <svg class="mfs-search-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
        <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" />
        <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
      </svg>
      <input
        type="search"
        name="q"
        value={filters.q ?? ''}
        placeholder="Search places, dishes, suburbs…"
        enterkeyhint="search"
        autocomplete="off"
      />
    </div>

    <button type="button" class:list={['mfs-trigger', { on: activeCount > 0 }]} data-mfs-open aria-haspopup="dialog">
      <svg width="14" height="12" viewBox="0 0 13 11" fill="none" aria-hidden="true">
        <path d="M0 1h13M2 5.5h9M4.5 10h4" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" />
      </svg>
      <span>Filters{activeCount > 0 && ` · ${activeCount}`}</span>
    </button>
  </form>

  <div class="mfs-sort-row">
    <span class="mfs-sort-label">Sort</span>
    <a class="mfs-sort-cycle" href={nextSortHref} aria-label={`Sorted by ${SORT_LONG_LABELS[sort]}. Tap to cycle.`}>
      <span>{SORT_LONG_LABELS[sort]}</span>
      <svg width="11" height="11" viewBox="0 0 12 12" fill="none" aria-hidden="true">
        <path d="M3 4.5l3-3 3 3M3 7.5l3 3 3-3" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round" />
      </svg>
    </a>
    <span class="mfs-count">
      <strong>{count}</strong> {count === 1 ? 'place' : 'places'}
    </span>
  </div>

  {/* Always rendered so the client-side filter engine has a stable target
      to inject chips into. Hidden via inline style when empty. */}
  <div class="mfs-applied" aria-label="Applied filters" style={activeChips.length > 0 ? '' : 'display: none'}>
    {activeChips.map((chip) => (
      <a href={chip.href} class="mfs-applied-chip" aria-label={`Remove ${chip.label}`}>
        <span>{chip.label}</span>
        <span class="x" aria-hidden="true">×</span>
      </a>
    ))}
    {activeChips.length > 0 && (
      <a href={clearAllHref} class="mfs-applied-clear" data-clear-all>Clear all</a>
    )}
  </div>
</div>

<div class="mfs-root" data-mfs-root aria-hidden="true">
  <div class="mfs-scrim" data-mfs-close></div>
  <div class="mfs-sheet" role="dialog" aria-modal="true" aria-labelledby="mfs-title">
    <div class="mfs-grabber" aria-hidden="true"></div>
    <header class="mfs-header">
      <h2 id="mfs-title">Filters</h2>
      <a href={clearAllHref} class="mfs-reset">Reset all</a>
    </header>

    <form method="get" action="/all" class="mfs-body">
      {/* Preserve the current search query so applying filters from the sheet
          doesn't wipe out an active search. */}
      {filters.q && <input type="hidden" name="q" value={filters.q} />}
      {/* Preserve map view when applying filters from the sheet. */}
      {view === 'map' && <input type="hidden" name="view" value="map" />}
      <!-- Sort -->
      <div class="mfs-group">
        <div class="mfs-legend">Sort</div>
        <div class="mfs-segments">
          {SORT_OPTIONS.map((opt) => (
            <label class:list={['mfs-seg', { on: sort === opt.value }]}>
              <input type="radio" name="sort" value={opt.value === 'name' ? '' : opt.value} checked={sort === opt.value} />
              <span>{opt.label}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Top rated -->
      <div class="mfs-group">
        <div class="mfs-legend">Rating</div>
        <input type="hidden" name="minRating" value={topRated ? String(TOP_RATED_THRESHOLD) : ''} data-mfs-toprated-input />
        <button
          type="button"
          class:list={['mfs-toprated', { on: topRated }]}
          data-mfs-toprated
          aria-pressed={topRated ? 'true' : 'false'}
        >
          <span class="check" aria-hidden="true">{topRated ? '✓' : ''}</span>
          <span>Top rated only ({TOP_RATED_THRESHOLD}+)</span>
        </button>
      </div>

      <!-- Status: All / Visited / On the list -->
      <div class="mfs-group">
        <div class="mfs-legend">Status</div>
        <div class="mfs-segments">
          {[
            { value: '', label: 'All' },
            { value: 'yes', label: 'Visited' },
            { value: 'no', label: 'On the list' },
          ].map((opt) => (
            <label class:list={['mfs-seg', { on: (filters.visited ?? '') === opt.value }]}>
              <input type="radio" name="visited" value={opt.value} checked={(filters.visited ?? '') === opt.value} />
              <span>{opt.label}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Cuisine — multi-select checkbox pills -->
      {cuisines.length > 0 && (
        <div class="mfs-group">
          <div class="mfs-legend">Cuisine</div>
          <div class="mfs-pills">
            {cuisines.map((c) => (
              <label class:list={['mfs-pill', { on: selectedCuisines.includes(c) }]}>
                <input type="checkbox" name="cuisine" value={c} checked={selectedCuisines.includes(c)} />
                <span>{c}</span>
              </label>
            ))}
          </div>
        </div>
      )}

      <!-- Location — multi-select checkbox pills (regions and suburbs) -->
      <div class="mfs-group">
        <div class="mfs-legend">Location</div>
        <div class="mfs-sub-label">Regions</div>
        <div class="mfs-pills">
          {regions.map((r) => (
            <label class:list={['mfs-pill', { on: selectedRegions.includes(r.slug) }]}>
              <input type="checkbox" name="location" value={`region:${r.slug}`} checked={selectedRegions.includes(r.slug)} />
              <span>{r.name}</span>
            </label>
          ))}
        </div>
        <div class="mfs-sub-label">Suburbs</div>
        <div class="mfs-pills">
          {locations.map((l) => (
            <label class:list={['mfs-pill', { on: selectedSuburbs.includes(l.slug) }]}>
              <input type="checkbox" name="location" value={l.slug} checked={selectedSuburbs.includes(l.slug)} />
              <span>{l.name}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Price -->
      <div class="mfs-group">
        <div class="mfs-legend">Price</div>
        <div class="mfs-pills">
          {PRICE_TIERS.map((p) => (
            <label class:list={['mfs-pill mfs-pill-price', { on: isPriceOn(p.tier) }]}>
              <input type="checkbox" name="price" value={p.tier} checked={isPriceOn(p.tier)} />
              <span class="sym">{p.symbol}</span>
              <span class="range">{p.range}</span>
            </label>
          ))}
        </div>
      </div>

      <!-- Vibe -->
      {vibes.length > 0 && (
        <div class="mfs-group">
          <div class="mfs-legend">Vibe</div>
          <div class="mfs-pills">
            {vibes.map((t) => (
              <label class:list={['mfs-pill', { on: isOn(filters.vibes, t.slug) }]}>
                <input type="checkbox" name="vibes" value={t.slug} checked={isOn(filters.vibes, t.slug)} />
                <span>{t.label}</span>
              </label>
            ))}
          </div>
        </div>
      )}

      <div class="mfs-cta-wrap">
        <button type="submit" class="mfs-cta">Show results</button>
      </div>
    </form>
  </div>
</div>

<script>
  // The site uses Astro View Transitions, which swaps the DOM on navigation
  // instead of reloading. So per-element listeners must be re-attached on
  // every `astro:page-load`. Global listeners (Escape, scroll-lock reset)
  // are attached once outside the per-page init.

  // Always clear any stale scroll lock when navigating away — otherwise a
  // sheet that was open on the previous page leaves body overflow:hidden.
  document.addEventListener('astro:before-swap', () => {
    document.body.style.overflow = '';
  });

  // Global Escape — re-queries the current root so it works after every swap.
  document.addEventListener('keydown', (e) => {
    if (e.key !== 'Escape') return;
    const root = document.querySelector<HTMLDivElement>('[data-mfs-root]');
    if (root && root.hasAttribute('data-open')) {
      root.removeAttribute('data-open');
      root.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    }
  });

  function dispatchFiltersChanged() {
    window.dispatchEvent(new CustomEvent('lucaseats:filters-changed'));
  }

  function initMobileFilterSheet() {
    const root = document.querySelector<HTMLDivElement>('[data-mfs-root]');
    const trigger = document.querySelector<HTMLButtonElement>('[data-mfs-open]');
    if (!root || !trigger) return;

    const openSheet = () => {
      root.setAttribute('data-open', '');
      root.setAttribute('aria-hidden', 'false');
      document.body.style.overflow = 'hidden';
    };
    const closeSheet = () => {
      root.removeAttribute('data-open');
      root.setAttribute('aria-hidden', 'true');
      document.body.style.overflow = '';
    };
    trigger.addEventListener('click', openSheet);
    root.querySelectorAll<HTMLElement>('[data-mfs-close]').forEach((el) => {
      el.addEventListener('click', closeSheet);
    });

    // --- Outer search row (always visible) ----------------------------
    // Live search with a small debounce. Native form submit is suppressed
    // so the page doesn't reload when the user hits Enter on the keyboard.
    const searchForm = document.querySelector<HTMLFormElement>('.mfs-search-row');
    const searchInput = searchForm?.querySelector<HTMLInputElement>('input[name="q"]');
    if (searchForm && searchInput) {
      searchForm.addEventListener('submit', (e) => {
        e.preventDefault();
        applyOuterParam('q', searchInput.value.trim());
      });
      let t: ReturnType<typeof setTimeout> | null = null;
      searchInput.addEventListener('input', () => {
        if (t) clearTimeout(t);
        t = setTimeout(() => applyOuterParam('q', searchInput.value.trim()), 180);
      });
    }

    // Sort cycle anchor — intercept the click so we don't full-reload.
    const sortCycle = document.querySelector<HTMLAnchorElement>('.mfs-sort-cycle');
    if (sortCycle) {
      sortCycle.addEventListener('click', (e) => {
        const href = sortCycle.getAttribute('href');
        if (!href) return;
        e.preventDefault();
        const dest = new URL(href, window.location.origin);
        // Carry the current view across — the anchor's href is built by
        // urlWithSort() which already preserves Astro.url params, but we
        // re-replaceState here to keep the soft-update flow consistent.
        window.history.replaceState({}, '', dest.toString());
        dispatchFiltersChanged();
      });
    }

    // --- Inner sheet form (batch-apply on Show Results) ---------------
    // Inside the sheet, individual control changes only update the visual
    // state. The user hits "Show results" to commit — this matches the
    // mobile UX where the sheet covers the page so live-filtering would
    // be invisible until they close it.
    const sheetForm = root.querySelector<HTMLFormElement>('.mfs-body');

    // Top rated toggle (visual only; commit on Show Results).
    const topRatedInput = root.querySelector<HTMLInputElement>('[data-mfs-toprated-input]');
    const topRatedBtn = root.querySelector<HTMLButtonElement>('[data-mfs-toprated]');
    if (topRatedInput && topRatedBtn) {
      topRatedBtn.addEventListener('click', () => {
        const willBeOn = topRatedInput.value === '';
        topRatedInput.value = willBeOn ? '7' : '';
        topRatedBtn.classList.toggle('on', willBeOn);
        topRatedBtn.setAttribute('aria-pressed', willBeOn ? 'true' : 'false');
        const check = topRatedBtn.querySelector<HTMLElement>('.check');
        if (check) check.textContent = willBeOn ? '✓' : '';
      });
    }

    // Radio segment groups (sort, status) — sync .on class on labels.
    // Sets within the same `name` group are mutually exclusive, so on
    // change we re-derive the .on state for every label in the sheet.
    root.querySelectorAll<HTMLInputElement>('input[type="radio"]').forEach((rb) => {
      rb.addEventListener('change', () => {
        root.querySelectorAll<HTMLLabelElement>('.mfs-seg').forEach((seg) => {
          const inner = seg.querySelector<HTMLInputElement>('input[type="radio"]');
          seg.classList.toggle('on', !!inner && inner.checked);
        });
      });
    });

    // Checkboxes (cuisine, location, price, vibes) — sync .on class on labels.
    root.querySelectorAll<HTMLInputElement>('input[type="checkbox"]').forEach((cb) => {
      cb.addEventListener('change', () => {
        const label = cb.closest<HTMLLabelElement>('label');
        if (label) label.classList.toggle('on', cb.checked);
      });
    });

    // Show Results — collect form state, replace URL, dispatch, close.
    if (sheetForm) {
      sheetForm.addEventListener('submit', (e) => {
        e.preventDefault();
        commitSheetForm(sheetForm);
        closeSheet();
      });
    }
  }

  function applyOuterParam(name: string, value: string) {
    const url = new URL(window.location.href);
    url.searchParams.delete(name);
    if (value) url.searchParams.append(name, value);
    window.history.replaceState({}, '', url.toString());
    dispatchFiltersChanged();
  }

  function commitSheetForm(form: HTMLFormElement) {
    const url = new URL(window.location.href);
    // Preserve view + q (managed by the outer bar) and clear/repopulate
    // every param the sheet controls.
    const sheetManagedNames = ['cuisine', 'location', 'price', 'vibes', 'minRating', 'sort', 'visited'];
    for (const n of sheetManagedNames) url.searchParams.delete(n);

    const data = new FormData(form);
    for (const name of sheetManagedNames) {
      // Skip the "" radio for sort (means default) so we keep the URL clean.
      const values = data.getAll(name).filter((v) => typeof v === 'string' && v.length > 0) as string[];
      for (const v of values) url.searchParams.append(name, v);
    }
    window.history.replaceState({}, '', url.toString());
    dispatchFiltersChanged();
  }

  // Fires on the initial page load and after every View Transitions swap.
  document.addEventListener('astro:page-load', initMobileFilterSheet);
</script>

<style>
  /* Hidden by default; only mounted on mobile */
  .mfs-bar, .mfs-root { display: none; }

  @media (max-width: 768px) {
    .mfs-bar {
      position: relative;
      display: flex;
      flex-direction: column;
      gap: 0.65rem;
      max-width: 1180px;
      margin: 0 auto;
      padding: 0.75rem 1rem 0.85rem;
      border-top: 1px solid var(--rule);
      border-bottom: 1px solid var(--rule);
      background: var(--paper);
    }

    /* Floats above the bar in the page-head's bottom padding so it consumes
       zero vertical layout space — the restaurant list isn't pushed down. The
       right-side padding is calibrated so the arrow's tip lands roughly over
       the centre of the Filters button. */
    .mfs-trigger-cta {
      position: absolute;
      bottom: calc(100% - 0.25rem);
      right: 0;
      padding-right: 3.6rem;
      display: flex;
      align-items: flex-start;
      gap: 0.4rem;
      color: var(--terracotta);
      pointer-events: none;
      z-index: 1;
    }
    .mfs-trigger-cta-label {
      font-family: var(--sans);
      font-size: 0.6875rem;
      font-weight: 700;
      letter-spacing: 0.14em;
      text-transform: uppercase;
      padding-top: 0.2rem;
    }
    .mfs-trigger-cta-arrow {
      animation: mfs-trigger-cta-nudge 1.6s ease-in-out infinite;
      flex-shrink: 0;
    }
    @keyframes mfs-trigger-cta-nudge {
      0%, 100% { transform: translate(0, 0); }
      50%      { transform: translate(2px, 3px); }
    }
    @media (prefers-reduced-motion: reduce) {
      .mfs-trigger-cta-arrow { animation: none; }
    }
    /* Row 1: search input + Filters trigger */
    .mfs-search-row {
      display: flex;
      gap: 0.5rem;
      align-items: center;
    }
    .mfs-search-input-wrap {
      position: relative;
      flex: 1;
      min-width: 0;
    }
    .mfs-search-icon {
      position: absolute;
      left: 0.75rem;
      top: 50%;
      transform: translateY(-50%);
      color: var(--muted);
      pointer-events: none;
    }
    .mfs-search-input-wrap input[type="search"] {
      width: 100%;
      height: 38px;
      padding: 0 0.85rem 0 2.05rem;
      border: 1px solid var(--rule);
      border-radius: 999px;
      background: var(--bg);
      color: var(--ink);
      font-family: var(--sans);
      font-size: 0.875rem;
      outline: none;
      -webkit-appearance: none;
      appearance: none;
    }
    .mfs-search-input-wrap input[type="search"]::placeholder { color: var(--muted); }
    .mfs-search-input-wrap input[type="search"]:focus {
      border-color: var(--ink);
    }
    /* Strip the native clear button on WebKit so it doesn't fight our styling */
    .mfs-search-input-wrap input[type="search"]::-webkit-search-cancel-button {
      -webkit-appearance: none;
    }

    /* Row 2: sort label/cycle + count */
    .mfs-sort-row {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      padding: 0 0.15rem;
    }
    .mfs-sort-label {
      font-family: var(--sans);

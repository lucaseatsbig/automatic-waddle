---
import type { FeaturedPlaceData } from '../lib/db';
import { placePhotoUrl } from '../lib/places';

interface Props {
  place: FeaturedPlaceData;
  photosBase: string;
}
const { place: p, photosBase } = Astro.props;

const uploadedCover = p.cover_r2_key && photosBase ? `${photosBase}/${p.cover_r2_key}` : null;
const placesCover = p.hero_photo_name ? placePhotoUrl(p.hero_photo_name, 600) : null;
const heroSrc = uploadedCover ?? placesCover;

const ratingFmt = p.rating_overall != null ? p.rating_overall.toFixed(1) : null;
const visitYear = p.latest_visit_date ? new Date(p.latest_visit_date).getFullYear() : null;
const mealLabel = p.latest_meal_type ? p.latest_meal_type.toUpperCase() : 'VISIT';

function excerpt(s: string | null, max = 90): string {
  if (!s) return '';
  if (s.length <= max) return s;
  const cut = s.slice(0, max);
  const space = cut.lastIndexOf(' ');
  return (space > 0 ? cut.slice(0, space) : cut) + '…';
}
---
<a href={`/restaurants/${p.slug}`} class="featured">
  <div class="block">
    {heroSrc
      ? <img src={heroSrc} alt={p.name} loading="lazy" decoding="async" width="800" height="600" />
      : <div class="placeholder" aria-hidden="true"></div>}
    <div class="overlay">
      <div class="badge">
        {mealLabel}{visitYear ? ` · ${visitYear}` : ''}
      </div>
      {ratingFmt && (
        <div class="rating">
          <span class="rating-num">{ratingFmt}</span>
          <span class="rating-denom">/10</span>
        </div>
      )}
    </div>
  </div>
  <div class="body">
    <h3 class="name">{p.name}</h3>
    {p.commentary && <p class="commentary">{excerpt(p.commentary)}</p>}
    {p.tags.length > 0 && (
      <div class="chips">
        {p.tags.slice(0, 3).map((t) => (
          <span class="chip">{t.label.toLowerCase()}</span>
        ))}
      </div>
    )}
    <div class="meta">
      {p.review_count === 1 ? '1 visit' : `${p.review_count} visits`}
      {p.location && <> · {p.location}</>}
    </div>
  </div>
</a>

<style>
  .featured {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 14px;
    overflow: hidden;
    box-shadow: 0 1px 2px rgba(26, 40, 32, 0.04);
    transition: transform 0.15s, box-shadow 0.15s, border-color 0.15s;
  }
  .featured:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(26, 40, 32, 0.1);
    border-color: var(--rule-strong);
  }
  .block {
    position: relative;
    aspect-ratio: 4 / 3;
    width: 100%;
    flex-shrink: 0;
    overflow: hidden;
    background: var(--paper);
  }
  .block img {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder {
    position: absolute;
    inset: 0;
    background-image: repeating-linear-gradient(
      135deg,
      var(--paper) 0,
      var(--paper) 16px,
      rgba(26, 40, 32, 0.04) 16px,
      rgba(26, 40, 32, 0.04) 32px
    );
  }
  .overlay {
    position: absolute;
    inset: 0;
    padding: 0.85rem 1rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    background: linear-gradient(to bottom, rgba(0,0,0,0.45) 0%, rgba(0,0,0,0) 35%, rgba(0,0,0,0) 65%, rgba(0,0,0,0.35) 100%);
  }
  .badge {
    font-family: var(--sans);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.95);
    align-self: flex-start;
    background: rgba(0, 0, 0, 0.4);
    padding: 0.25rem 0.55rem;
    border-radius: 999px;
    backdrop-filter: blur(4px);
  }
  .rating {
    align-self: flex-end;
    background: var(--bg);
    color: var(--terracotta);
    padding: 0.35rem 0.6rem;
    border-radius: 999px;
    font-family: var(--serif);
    line-height: 1;
  }
  .rating-num {
    font-size: 1.1rem;
    font-weight: 600;
  }
  .rating-denom {
    font-size: 0.7rem;
    color: var(--muted);
    margin-left: 0.1rem;
  }
  .body {
    padding: 0.95rem 1.1rem 1.1rem;
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .name {
    font-family: var(--serif);
    font-size: 1.15rem;
    font-weight: 500;
    margin: 0;
    color: var(--ink);
    letter-spacing: -0.015em;
    line-height: 1.25;
  }
  .commentary {
    font-family: var(--serif);
    margin: 0;
    color: var(--ink);
    opacity: 0.75;
    font-size: 0.875rem;
    line-height: 1.5;
    font-style: italic;
  }
  .chips {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
  }
  .chip {
    font-family: var(--sans);
    font-size: 0.6875rem;
    padding: 0.2rem 0.6rem;
    border-radius: 999px;
    background: var(--paper);
    border: 1px solid var(--rule);
    color: var(--ink);
  }
  .meta {
    font-family: var(--sans);
    margin-top: auto;
    color: var(--muted);
    font-size: 0.75rem;
  }
</style>

---
import type { RestaurantCardData } from '../lib/types';
import { placePhotoUrl } from '../lib/places';
import Rating from './Rating.astro';

interface Props {
  restaurant: RestaurantCardData;
  photosBase: string;
  hideOnDesktop?: boolean;
  /**
   * Force the narrow "mobile" layout (88px thumb, inline rating, tags below)
   * at every viewport. Use when the card sits in a multi-column grid where
   * the wide 5-column layout would be cramped — e.g. the home page 2-col grid.
   */
  compact?: boolean;
}
const { restaurant: r, photosBase, hideOnDesktop = false, compact = false } = Astro.props;

const uploadedCover = r.cover_r2_key && photosBase ? `${photosBase}/${r.cover_r2_key}` : null;
const placesCover = r.hero_photo_name ? placePhotoUrl(r.hero_photo_name, 200) : null;
const heroSrc = uploadedCover ?? placesCover;

const priceSymbol = r.price_tier ? '$'.repeat(r.price_tier) : '';

function timeAgo(iso: string | null): string | null {
  if (!iso) return null;
  const then = new Date(iso).getTime();
  if (Number.isNaN(then)) return null;
  const days = Math.floor((Date.now() - then) / (1000 * 60 * 60 * 24));
  if (days < 1) return 'today';
  if (days < 7) return `${days}d ago`;
  if (days < 30) return `${Math.floor(days / 7)}w ago`;
  if (days < 365) return `${Math.floor(days / 30)}mo ago`;
  const yrs = Math.floor(days / 365);
  return yrs === 1 ? '1yr ago' : `${yrs}yrs ago`;
}

const ago = r.visited ? timeAgo(r.latest_visit_date) : null;

// Surface vibe tags first ("date spot", "casual"), then dietary, then other.
// Vibes are the most useful at-a-glance signal for browsing.
const categoryOrder: Record<string, number> = { vibe: 0, dietary: 1, other: 2 };
const sortedTags = [...r.tags]
  .sort((a, b) => (categoryOrder[a.category] ?? 99) - (categoryOrder[b.category] ?? 99));
const desktopTags = sortedTags.slice(0, 4);
// Render up to 3 chips in mobile-tags (used for: actual mobile + compact at
// any viewport). On true narrow phones chip #3 is hidden via CSS so we cap
// at 2; on desktop-compact (home-page 2-col grid) all 3 show. Cap is 3 so
// chips fit on a single row even in the narrow 2-col card.
const mobileTags = sortedTags.slice(0, 3);
const mobileOverflowNarrow = Math.max(0, sortedTags.length - 2);
const mobileOverflowWide = Math.max(0, sortedTags.length - 3);
---
<a
  href={`/restaurants/${r.slug}`}
  class:list={['card', { wishlist: !r.visited, 'desktop-hide': hideOnDesktop, compact }]}
>
  <div class="thumb">
    {heroSrc
      ? <img src={heroSrc} alt="" loading="lazy" decoding="async" width="104" height="104" />
      : <div class="placeholder" aria-hidden="true">{r.name.charAt(0).toUpperCase()}</div>}
  </div>
  <div class="lead">
    <div class="title-row">
      <span class="name">{r.name}</span>
      <span class="rating-slot">
        {r.visited
          ? <Rating value={r.avg_overall} size="md" />
          : (
            <span class="wishlist-marker">
              <span class="wishlist-rating">–<span class="wishlist-denom">/10</span></span>
              <span class="wishlist-tag">WISHLIST</span>
            </span>
          )}
      </span>
    </div>
    {/* Single-line meta with ellipsis. Multi-cuisine restaurants ("Italian, Japanese")
        show only the first cuisine in cards; the detail page still lists everything. */}
    <div class="meta-line">
      {r.cuisine && <span class="meta-item">{r.cuisine.split(',')[0].trim()}</span>}
      {r.location && <span class="meta-item">{r.location}</span>}
      {priceSymbol && <span class="meta-item price">{priceSymbol}</span>}
    </div>
    {!r.visited && r.wishlist_note && <p class="note">{r.wishlist_note}</p>}
    <div class="mobile-tags">
      {mobileTags.map((t, i) => (
        <span class:list={[`chip chip-${t.category}`, { 'chip-extra': i >= 2 }]}>{t.label.toLowerCase()}</span>
      ))}
      {mobileOverflowNarrow > 0 && <span class="more-tags more-tags-narrow">+{mobileOverflowNarrow}</span>}
      {mobileOverflowWide > 0 && <span class="more-tags more-tags-wide">+{mobileOverflowWide}</span>}
    </div>
  </div>
  <div class="tags-col">
    {desktopTags.map((t) => (
      <span class={`chip chip-${t.category}`}>{t.label.toLowerCase()}</span>
    ))}
  </div>
  <div class="when">{ago ?? (r.visited ? '–' : '')}</div>
  <div class="rating-col">
    {r.visited
      ? <Rating value={r.avg_overall} size="md" />
      : (
        <span class="wishlist-marker">
          <span class="wishlist-rating">–<span class="wishlist-denom">/10</span></span>
          <span class="wishlist-tag">WISHLIST</span>
        </span>
      )}
  </div>
</a>

<style>
  /* === Base styles (mobile-first) ===
     Below 720px the card uses a 2-col layout (thumb + lead) with smaller
     type. The desktop bump (bigger thumb, bigger type, 5-col grid for the
     non-compact variant) only kicks in at the @media (min-width: 720px)
     block further down. */
  .card {
    display: grid;
    grid-template-columns: 88px 1fr;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--rule);
    border-radius: 12px;
    background: var(--bg);
    transition: border-color 0.1s, background 0.1s;
    -webkit-tap-highlight-color: transparent;
  }
  /* Only apply hover styling on devices that can actually hover (mouse).
     Without this, mobile Safari leaves the :hover state stuck on the last
     tapped card until you tap elsewhere — looks like a stray orange border. */
  @media (hover: hover) {
    .card:hover { border-color: var(--terracotta); background: var(--paper); }
    .card.wishlist:hover { border-color: var(--forest-soft); }
  }
  .card.wishlist {
    border: 1px dashed var(--rule-strong);
    background: var(--paper);
  }

  .thumb {
    width: 88px;
    height: 88px;
    border-radius: 10px;
    overflow: hidden;
    background: var(--paper);
    flex-shrink: 0;
  }
  .thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--serif);
    font-size: 1.5rem;
    color: var(--muted);
    background-image: repeating-linear-gradient(
      135deg,
      var(--paper) 0,
      var(--paper) 8px,
      rgba(26, 40, 32, 0.04) 8px,
      rgba(26, 40, 32, 0.04) 16px
    );
  }

  /* .lead is the positioning anchor for the absolute-positioned rating-slot.
     Reserving padding-right keeps name/meta/chips from running underneath
     the rating overlay on the right. */
  .lead {
    min-width: 0;
    position: relative;
    padding-right: 4.25rem;
  }
  .title-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    margin-bottom: 0.35rem;
    min-width: 0;
  }
  .name {
    font-family: var(--serif);
    font-size: 1.0625rem;
    font-weight: 500;
    color: var(--ink);
    line-height: 1.2;
    letter-spacing: -0.01em;
    flex: 1 1 auto;
    min-width: 0;
    /* 2-line clamp — long names wrap to a known max instead of pushing the
       rating off the row or breaking the grid. */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  /* Rating slot (and wishlist label) absolute-positioned to the top-right of
     .lead. Out of flex flow so a high-tier pill (taller than plain text)
     can't push the meta-line down — keeps the gap between name and meta
     consistent across rating tiers. */
  .rating-slot {
    position: absolute;
    top: 0;
    right: 0;
  }
  /* Wishlist marker — sits in the same slot as a visited card's rating.
     A muted "–/10" placeholder occupies the rating position (matching the
     visited cards' rating size) with a small "WISHLIST" pill stacked below
     to make the wishlist state explicit. */
  .wishlist-marker {
    display: inline-flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.3rem;
    line-height: 1;
  }
  .wishlist-rating {
    font-family: var(--serif);
    font-size: 18px;
    font-weight: 600;
    color: var(--muted);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .wishlist-denom {
    font-size: 9px;
    color: var(--muted);
    margin-left: 0.05rem;
    font-weight: 500;
  }
  .wishlist-tag {
    font-family: var(--sans);
    font-size: 0.625rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    text-transform: uppercase;
    color: var(--forest-soft);
    background: rgba(45, 69, 56, 0.1);
    border: 1px solid rgba(45, 69, 56, 0.3);
    padding: 0.18rem 0.5rem;
    border-radius: 999px;
    line-height: 1.2;
  }
  @media (min-width: 720px) {
    .wishlist-rating { font-size: 26px; }
    .wishlist-denom { font-size: 12px; }
    .wishlist-tag { font-size: 0.6875rem; padding: 0.2rem 0.55rem; }
  }

  .meta-line {
    font-family: var(--sans);
    font-size: 0.8125rem;
    color: var(--muted);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
    margin-bottom: 0.4rem;
  }
  .meta-item + .meta-item::before {
    content: '·';
    margin: 0 0.4rem;
    color: var(--rule-strong);
  }
  .meta-item.price {
    font-weight: 600;
    color: var(--ink);
  }

  .note {
    font-family: var(--serif);
    color: var(--ink);
    font-size: 0.8125rem;
    font-style: italic;
    margin: 0.3rem 0 0;
    line-height: 1.4;
    opacity: 0.75;
  }

  /* Tag columns — at base (mobile/compact) only .mobile-tags renders.
     The wide .tags-col + .when + .rating-col belong to the 5-col desktop
     non-compact layout and stay hidden until the @media block below.
     .mobile-tags is forced to a single row; chips that overflow are clipped
     by the parent .lead's overflow rule rather than wrapping. */
  .mobile-tags {
    display: flex;
    gap: 0.35rem;
    flex-wrap: nowrap;
    overflow: hidden;
    justify-content: flex-start;
    margin-top: 0.5rem;
  }
  .tags-col {
    display: none;
    gap: 0.35rem;
    flex-wrap: wrap;
    justify-content: flex-start;
  }
  .chip {
    font-family: var(--sans);
    font-size: 0.6875rem;
    padding: 0.18rem 0.55rem;
    border-radius: 999px;
    background: var(--paper);
    border: 1px solid var(--rule);
    color: var(--ink);
    white-space: nowrap;
  }
  .chip-vibe { background: rgba(184, 84, 58, 0.08); border-color: rgba(184, 84, 58, 0.2); color: var(--terracotta); }
  .chip-dietary { background: rgba(45, 69, 56, 0.08); border-color: rgba(45, 69, 56, 0.2); color: var(--forest-soft); }
  .more-tags {
    font-family: var(--sans);
    font-size: 0.6875rem;
    color: var(--muted);
    font-weight: 500;
    align-self: center;
  }
  .when {
    display: none;
    font-family: var(--sans);
    color: var(--muted);
    font-size: 0.8125rem;
    text-align: right;
  }

  .rating-col {
    display: none;
    text-align: right;
  }

  @media (min-width: 601px) {
    .card.desktop-hide { display: none; }
  }

  /* === Compact-prop base ===
     Compact = forced narrow layout at any viewport (used on home/all/guides
     2-col grid + restaurant detail "Similar"). Inherits mobile-style sizing
     from the base .card rules; the desktop bump below adds bigger thumb/type. */
  .card.compact {
    grid-template-columns: 88px 1fr;
    gap: 0.75rem;
    padding: 0.625rem;
    border-radius: 12px;
  }
  .card.compact .thumb { width: 88px; height: 88px; border-radius: 10px; }
  .card.compact .tags-col,
  .card.compact .when,
  .card.compact .rating-col { display: none; }
  .card.compact .rating-slot { display: inline-flex; align-items: baseline; }
  .card.compact .mobile-tags { display: flex; }

  /* === Desktop bump (≥720px) ===
     Bigger thumbs and type for both layouts:
     - Non-compact: switches to 5-col wide grid + reveals tags-col / when / rating-col.
     - Compact: stays 2-col but bumped (124px thumb, bigger type).
     Below 720px both stay at the mobile-friendly base sizing above. */
  @media (min-width: 720px) {
    .name { font-size: 1.3125rem; }
    .title-row { margin-bottom: 0.5rem; }
    .meta-line { font-size: 0.9375rem; margin-bottom: 0.55rem; }
    .chip { font-size: 0.8125rem; padding: 0.25rem 0.65rem; }
    .note { font-size: 0.9375rem; }

    /* Non-compact: 5-col wide grid */
    .card:not(.compact) {
      grid-template-columns: 124px minmax(0, 2.4fr) minmax(0, 1.6fr) 80px auto;
      gap: 1.1rem;
      padding: 0.95rem 1.1rem;
      border-radius: 14px;
    }
    .card:not(.compact) .thumb { width: 124px; height: 124px; border-radius: 12px; }
    .card:not(.compact) .tags-col { display: flex; }
    .card:not(.compact) .when { display: block; font-size: 0.9375rem; }
    .card:not(.compact) .rating-col { display: block; }
    /* Wide layout uses tags-col + rating-col, so hide the inline mobile-tags
       and rating-slot to avoid double-rendering. */
    .card:not(.compact) .mobile-tags { display: none; }
    .card:not(.compact) .rating-slot { display: none; }
    /* No need to reserve title-row space for the rating since it lives in
       rating-col on this layout. */
    .card:not(.compact) .lead { padding-right: 0; }

    /* Compact: stays 2-col but with the desktop bump applied. */
    .card.compact {
      grid-template-columns: 124px 1fr;
      gap: 1rem;
      padding: 0.95rem;
      border-radius: 12px;
    }
    .card.compact .thumb { width: 124px; height: 124px; border-radius: 10px; }
    .card.compact .lead { padding-right: 5rem; }
    .card.compact .mobile-tags { gap: 0.4rem; margin-top: 0.6rem; }
  }

  /* Inline rating in cards — Rating is rendered with size="md" so it reads
     well on desktop, but on phones we scale it down to roughly sm sizing so
     it doesn't dominate the narrow card. Scoped to .card so other md ratings
     (e.g. about-page tier demos) keep their full size. */
  @media (max-width: 719px) {
    .card :global(.rating-md .num) { font-size: 18px; }
    .card :global(.rating-md .denom) { font-size: 9px; }
    .card :global(.rating-high.rating-md) { padding: 3px 8px; }
  }

  /* Chip overflow indicators — show the right one per viewport.
     On narrow viewports we cap at 2 chips (hide chip-extra) and show the
     "narrow" overflow count. On wide viewports show all 4 chips and the
     "wide" overflow count. The .mobile-tags container is itself hidden on
     non-compact desktop (existing rule), so these only apply where it
     actually renders. */
  .more-tags-wide { display: none; }
  @media (max-width: 720px) {
    .mobile-tags .chip-extra { display: none; }
  }
  @media (min-width: 721px) {
    .more-tags-narrow { display: none; }
    .more-tags-wide { display: inline; }
  }
</style>

---
interface Props {
  active: 'home' | 'all' | 'about';
}
const { active } = Astro.props;
---
<header class="masthead">
  <div class="brand">
    <a href="/" class="brand-link">
      <span class="brand-name">lucaseats<span class="brand-dot">big</span></span>
    </a>
  </div>
  <nav class="nav">
    <a href="/" class={`nav-link ${active === 'home' ? 'active' : ''}`}>home</a>
    <a href="/all" class={`nav-link ${active === 'all' ? 'active' : ''}`}>all places</a>
    <a href="/about" class={`nav-link ${active === 'about' ? 'active' : ''}`}>about</a>
  </nav>
</header>

<style>
  .masthead {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.1rem 1.5rem;
    border-bottom: 1px solid var(--rule);
    max-width: 1280px;
    margin: 0 auto;
    gap: 1rem;
    flex-wrap: nowrap;
  }
  @media (max-width: 640px) {
    .masthead {
      padding: 0.75rem 0.9rem;
      gap: 0.5rem;
    }
    .nav { gap: 0.85rem; font-size: 0.8125rem; }
    .brand-name { font-size: 1.05rem; }
  }
  @media (max-width: 380px) {
    .masthead { gap: 0.4rem; }
    .nav { gap: 0.7rem; font-size: 0.78rem; }
    .brand-name { font-size: 0.98rem; }
  }
  .brand-link { text-decoration: none; }
  .brand-name {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.25rem;
    color: var(--ink);
    letter-spacing: -0.015em;
    font-weight: 500;
    white-space: nowrap;
  }
  .brand-dot { color: var(--terracotta); }
  .nav {
    display: flex;
    gap: 1.5rem;
    font-family: var(--sans);
    font-size: 0.875rem;
    white-space: nowrap;
  }
  .nav-link {
    color: var(--muted);
    text-decoration: none;
    padding: 0.25rem 0;
    border-bottom: 2px solid transparent;
    transition: color 0.1s, border-color 0.1s;
  }
  .nav-link:hover { color: var(--ink); }
  .nav-link.active {
    color: var(--ink);
    border-bottom-color: var(--terracotta);
  }
</style>

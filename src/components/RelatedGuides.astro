---
// "See also" cross-link panel rendered at the bottom of each guide. Surfaces
// other published guides whose featured restaurants overlap with this one's
// — that's the internal-link compounding that drives SEO juice across the
// guide hub.
//
// Receives a pre-fetched list from getRelatedPosts() so the page-level Astro
// component can decide whether to render the panel at all.
import type { RelatedPostSummary } from '../lib/posts';
import { placePhotoUrl } from '../lib/places';

interface Props {
  guides: RelatedPostSummary[];
  photosBase: string;
}
const { guides, photosBase } = Astro.props as Props;

function thumbSrc(g: RelatedPostSummary): string | null {
  if (g.og_image_cover_r2_key && photosBase) {
    return `${photosBase}/${g.og_image_cover_r2_key}`;
  }
  if (g.og_image_hero_photo_name) {
    return placePhotoUrl(g.og_image_hero_photo_name, 320);
  }
  return null;
}
---
{guides.length > 0 && (
  <section class="related" aria-labelledby="related-heading">
    <h2 id="related-heading">See also</h2>
    <ul class="related-list">
      {guides.map((g) => {
        const src = thumbSrc(g);
        return (
          <li class="related-item">
            <a href={`/guides/${g.slug}`} class="related-link">
              {src ? (
                <img class="related-thumb" src={src} alt="" loading="lazy" decoding="async" />
              ) : (
                <div class="related-thumb-placeholder" aria-hidden="true" />
              )}
              <div class="related-text">
                <p class="related-kicker">{g.kind.toUpperCase()} · GUIDE</p>
                <p class="related-title">{g.title}</p>
                <p class="related-desc">{g.description}</p>
              </div>
            </a>
          </li>
        );
      })}
    </ul>
  </section>
)}

<style>
  .related {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 1px solid var(--rule);
  }
  .related h2 {
    font-family: var(--serif);
    font-style: italic;
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 1.25rem;
    letter-spacing: -0.015em;
  }
  .related-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.75rem;
  }
  @media (min-width: 720px) {
    .related-list { grid-template-columns: 1fr 1fr; gap: 1rem; }
  }
  .related-item { margin: 0; }
  .related-link {
    display: flex;
    gap: 0.85rem;
    text-decoration: none;
    color: inherit;
    padding: 0.7rem;
    border: 1px solid var(--rule);
    border-radius: 12px;
    transition: border-color 0.15s, transform 0.15s;
  }
  @media (hover: hover) {
    .related-link:hover {
      border-color: var(--terracotta);
      transform: translateY(-1px);
    }
  }
  .related-thumb,
  .related-thumb-placeholder {
    flex-shrink: 0;
    width: 88px;
    height: 88px;
    border-radius: 8px;
    object-fit: cover;
    background: var(--paper);
  }
  .related-thumb-placeholder {
    background-image: repeating-linear-gradient(
      135deg,
      var(--paper) 0,
      var(--paper) 8px,
      rgba(26, 40, 32, 0.04) 8px,
      rgba(26, 40, 32, 0.04) 16px
    );
  }
  .related-text { min-width: 0; }
  .related-kicker {
    font-family: var(--sans);
    font-size: 0.625rem;
    letter-spacing: 0.14em;
    color: var(--muted);
    font-weight: 600;
    text-transform: uppercase;
    margin: 0 0 0.25rem;
  }
  .related-title {
    font-family: var(--serif);
    font-size: 1rem;
    font-weight: 500;
    color: var(--ink);
    margin: 0 0 0.25rem;
    line-height: 1.25;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
  .related-desc {
    font-family: var(--sans);
    font-size: 0.8125rem;
    color: var(--muted);
    margin: 0;
    line-height: 1.4;
    overflow: hidden;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }
</style>

---
import type { RestaurantCardData } from '../lib/types';
import { placePhotoUrl } from '../lib/places';

interface Props {
  items: RestaurantCardData[];
  photosBase: string;
  apiKey: string;
}

const { items, photosBase, apiKey } = Astro.props;

const mapItems = items
  .filter((r) => typeof r.lat === 'number' && typeof r.lng === 'number')
  .map((r) => {
    // Same priority as HomeListCard: user-uploaded R2 cover first, then the
    // Google Places hero photo. Width 400 keeps the popup thumb crisp without
    // pulling huge files for what's only ~200px on screen.
    const uploadedCover =
      r.cover_r2_key && photosBase ? `${photosBase}/${r.cover_r2_key}` : null;
    const placesCover = r.hero_photo_name ? placePhotoUrl(r.hero_photo_name, 400) : null;
    return {
      id: r.id,
      slug: r.slug,
      name: r.name,
      cuisine: r.cuisine,
      location: r.location,
      rating: r.avg_overall,
      visited: r.visited,
      lat: r.lat as number,
      lng: r.lng as number,
      thumb: uploadedCover ?? placesCover,
    };
  });

const missingCoords = items.length - mapItems.length;
const mapDataJson = JSON.stringify(mapItems).replace(/</g, '\\u003c');
---

<div class="map-wrap">
  {mapItems.length === 0 ? (
    <div class="map-empty">
      <p>No places to map.</p>
      {missingCoords > 0 && <p class="map-missing">{missingCoords} place{missingCoords === 1 ? '' : 's'} missing coordinates.</p>}
    </div>
  ) : (
    <div class="map-shell">
      <div id="lucaseats-gmap" class="gmap-host" data-api-key={apiKey}></div>

      <div class="map-legend" aria-label="Map legend">
        <div class="legend-row"><span class="dot dot-visited" aria-hidden="true"></span> Visited</div>
        <div class="legend-row"><span class="dot dot-wishlist" aria-hidden="true"></span> On the list</div>
      </div>

      <button type="button" class="locate-btn" id="lucaseats-locate" aria-label="Show my location" title="Show my location">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="12" cy="12" r="3"></circle>
          <path d="M12 2v3M12 19v3M2 12h3M19 12h3"></path>
          <circle cx="12" cy="12" r="9"></circle>
        </svg>
      </button>

      {missingCoords > 0 && (
        <p class="map-missing">{missingCoords} place{missingCoords === 1 ? '' : 's'} not pinned (missing coordinates).</p>
      )}
    </div>
  )}
</div>

<script id="lucaseats-map-data" type="application/json" is:inline set:html={mapDataJson}></script>

<script>
  type MapItem = {
    id: number;
    slug: string;
    name: string;
    cuisine: string | null;
    location: string | null;
    rating: number | null;
    visited: boolean;
    lat: number;
    lng: number;
    thumb: string | null;
  };

  declare global {
    interface Window {
      google?: any;
      __lucaseatsMap?: { init: () => Promise<void>; invalidate: () => void };
      __lucaseatsGmapsCallback?: () => void;
    }
  }

  let initialized = false;
  let mapRef: any = null;
  let userMarker: any = null;
  let userAccuracyCircle: any = null;
  let loadingPromise: Promise<any> | null = null;

  function escapeHtml(s: string): string {
    return s.replace(/[&<>"']/g, (c) =>
      ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c] as string)
    );
  }

  function loadGoogleMaps(apiKey: string): Promise<any> {
    if (window.google?.maps) return Promise.resolve(window.google.maps);
    if (loadingPromise) return loadingPromise;
    loadingPromise = new Promise((resolve, reject) => {
      window.__lucaseatsGmapsCallback = () => {
        if (window.google?.maps) resolve(window.google.maps);
        else reject(new Error('Google Maps loaded but window.google.maps missing'));
      };
      const s = document.createElement('script');
      s.src = `https://maps.googleapis.com/maps/api/js?key=${encodeURIComponent(apiKey)}&v=weekly&loading=async&callback=__lucaseatsGmapsCallback`;
      s.async = true;
      s.defer = true;
      s.onerror = () => reject(new Error('Failed to load Google Maps JS'));
      document.head.appendChild(s);
    });
    return loadingPromise;
  }

  // Soft, off-white styling so the map blends with the editorial palette.
  const mapStyles: any[] = [
    { elementType: 'geometry', stylers: [{ color: '#f5ede0' }] },
    { elementType: 'labels.text.fill', stylers: [{ color: '#1A2820' }] },
    { elementType: 'labels.text.stroke', stylers: [{ color: '#FFF8F0' }] },
    { featureType: 'administrative', elementType: 'geometry.stroke', stylers: [{ color: '#cdbfa4' }] },
    { featureType: 'poi', stylers: [{ visibility: 'off' }] },
    { featureType: 'poi.park', elementType: 'geometry', stylers: [{ color: '#d8e1c8' }] },
    { featureType: 'poi.park', elementType: 'labels', stylers: [{ visibility: 'off' }] },
    { featureType: 'road', elementType: 'geometry', stylers: [{ color: '#fcf6ea' }] },
    { featureType: 'road.highway', elementType: 'geometry', stylers: [{ color: '#f0e1c4' }] },
    { featureType: 'road', elementType: 'labels.icon', stylers: [{ visibility: 'off' }] },
    { featureType: 'transit', stylers: [{ visibility: 'off' }] },
    { featureType: 'water', elementType: 'geometry', stylers: [{ color: '#bcd4d4' }] },
    { featureType: 'water', elementType: 'labels.text.fill', stylers: [{ color: '#5a7a7a' }] },
  ];

  function buildPopupHtml(item: MapItem): string {
    const meta = [item.cuisine, item.location].filter((v): v is string => !!v).map(escapeHtml).join(' &middot; ');
    const ratingHtml =
      item.rating != null
        ? `<div class="popup-rating">${item.rating.toFixed(1)}<span>/10</span></div>`
        : `<div class="popup-status ${item.visited ? 'visited' : 'wishlist'}">${item.visited ? 'Visited' : 'On the list'}</div>`;
    const mapsHref =
      `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent(item.name + ' ' + (item.location ?? ''))}+${item.lat},${item.lng}`;
    const photoStyle = item.thumb ? `background-image: url('${item.thumb}')` : '';
    const photoClass = item.thumb ? 'popup-photo has-photo' : 'popup-photo no-photo';
    return `
      <div class="popup-card">
        <div class="${photoClass}" style="${photoStyle}">
          <button type="button" class="popup-close" aria-label="Close" onclick="window.__lucaseatsClosePopup&&window.__lucaseatsClosePopup()">
            <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true"><path d="M2 2 L12 12 M12 2 L2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/></svg>
          </button>
        </div>
        <a href="/restaurants/${item.slug}" class="popup-main">
          <div class="popup-info">
            <div class="popup-title-row">
              <div class="popup-name">${escapeHtml(item.name)}</div>
              ${ratingHtml}
            </div>
            ${meta ? `<div class="popup-meta">${meta}</div>` : ''}
          </div>
        </a>
        <a class="popup-maps-btn" href="${mapsHref}" target="_blank" rel="noopener">↗ Open in Maps</a>
      </div>
    `;
  }

  function markerIcon(maps: any, visited: boolean) {
    return {
      path: maps.SymbolPath.CIRCLE,
      scale: 7,
      fillColor: visited ? '#B8543A' : '#2D4538',
      fillOpacity: 0.95,
      strokeColor: '#FFF8F0',
      strokeWeight: 2,
    };
  }

  async function init() {
    if (initialized) return;
    const host = document.getElementById('lucaseats-gmap') as HTMLElement | null;
    const dataEl = document.getElementById('lucaseats-map-data');
    if (!host || !dataEl) return;

    const apiKey = host.dataset.apiKey || '';
    if (!apiKey) {
      host.innerHTML = '<p class="map-fail">Map unavailable — Google Maps API key not configured.</p>';
      return;
    }

    let items: MapItem[] = [];
    try {
      items = JSON.parse(dataEl.textContent || '[]');
    } catch {
      return;
    }
    if (items.length === 0) return;

    initialized = true;

    let maps: any;
    try {
      maps = await loadGoogleMaps(apiKey);
    } catch (err) {
      host.innerHTML = '<p class="map-fail">Couldn’t load Google Maps. Check your connection or API key.</p>';
      console.error(err);
      return;
    }

    const map = new maps.Map(host, {
      mapTypeControl: false,
      streetViewControl: false,
      fullscreenControl: false,
      gestureHandling: 'greedy',
      styles: mapStyles,
      backgroundColor: '#FFF8F0',
    });
    mapRef = map;

    const infoWindow = new maps.InfoWindow({ maxWidth: 280 });
    // Expose a global close-handler so our custom X button (rendered inside
    // the popup HTML) can dismiss the InfoWindow without us having to
    // re-attach a listener after every setContent call.
    (window as any).__lucaseatsClosePopup = () => infoWindow.close();
    const bounds = new maps.LatLngBounds();

    for (const item of items) {
      const marker = new maps.Marker({
        position: { lat: item.lat, lng: item.lng },
        map,
        title: item.name,
        icon: markerIcon(maps, item.visited),
        optimized: true,
      });
      marker.addListener('click', () => {
        infoWindow.setContent(buildPopupHtml(item));
        infoWindow.open({ map, anchor: marker });
      });
      bounds.extend({ lat: item.lat, lng: item.lng });
    }

    map.fitBounds(bounds, 32);
    // Cap initial zoom so a tight bounds (e.g. one suburb) doesn't slam to street level.
    maps.event.addListenerOnce(map, 'idle', () => {
      if (map.getZoom() > 15) map.setZoom(15);
    });

    // Wire the locate button.
    const locateBtn = document.getElementById('lucaseats-locate') as HTMLButtonElement | null;
    if (locateBtn) {
      locateBtn.addEventListener('click', () => locateUser(maps, map));
    }
  }

  function locateUser(maps: any, map: any) {
    if (!('geolocation' in navigator)) {
      alert('Geolocation isn’t supported in this browser.');
      return;
    }
    const btn = document.getElementById('lucaseats-locate') as HTMLButtonElement | null;
    if (btn) btn.classList.add('is-busy');
    navigator.geolocation.getCurrentPosition(
      (pos) => {
        if (btn) btn.classList.remove('is-busy');
        const { latitude, longitude, accuracy } = pos.coords;
        const here = { lat: latitude, lng: longitude };

        if (userMarker) userMarker.setMap(null);
        if (userAccuracyCircle) userAccuracyCircle.setMap(null);

        userAccuracyCircle = new maps.Circle({
          map,
          center: here,
          radius: Math.min(accuracy, 500),
          fillColor: '#1a73e8',
          fillOpacity: 0.12,
          strokeColor: '#1a73e8',
          strokeOpacity: 0.4,
          strokeWeight: 1,
        });

        userMarker = new maps.Marker({
          position: here,
          map,
          title: 'You are here',
          zIndex: 9999,
          icon: {
            path: maps.SymbolPath.CIRCLE,
            scale: 8,
            fillColor: '#1a73e8',
            fillOpacity: 1,
            strokeColor: '#FFF8F0',
            strokeWeight: 3,
          },
        });

        map.panTo(here);
        if (map.getZoom() < 13) map.setZoom(14);
      },
      (err) => {
        if (btn) btn.classList.remove('is-busy');
        const msg =
          err.code === err.PERMISSION_DENIED
            ? 'Location permission denied. Enable it in your browser settings to see yourself on the map.'
            : 'Could not get your location.';
        alert(msg);
      },
      { enableHighAccuracy: true, timeout: 10000, maximumAge: 60000 }
    );
  }

  window.__lucaseatsMap = {
    init,
    invalidate: () => {
      // Google Maps re-measures automatically on resize, but if the container
      // was display:none at init time, trigger a resize event after it shows.
      if (mapRef && window.google?.maps) {
        setTimeout(() => {
          window.google.maps.event.trigger(mapRef, 'resize');
        }, 0);
      }
    },
  };
</script>

<style is:global>
  /* Strip Google's InfoWindow shell — the default white border + drop shadow
     fights with our card styling. We make the IW container transparent and
     let `.popup-card` provide the cream background, border, and shadow. */
  .gm-style-iw.gm-style-iw-c {
    padding: 0 !important;
    background: transparent !important;
    box-shadow: none !important;
    border-radius: 0 !important;
    max-width: none !important;
  }
  .gm-style-iw .gm-style-iw-d {
    overflow: hidden !important;
    padding: 0 !important;
    max-height: none !important;
    background: transparent !important;
  }
  /* Hide Google's default close button — its position is computed against
     the IW container in ways that put it outside our card. We render our
     own .popup-close inside the popup HTML for precise placement. */
  .gm-style-iw button.gm-ui-hover-effect { display: none !important; }

  /* The popup card itself — uses the same elements & rhythm as HomeListCard:
     cream background, soft border, italic-serif name, terracotta rating,
     ink-pill "Open in Maps" button matching the rating-card on detail pages. */
  .popup-card {
    font-family: var(--sans, system-ui, sans-serif);
    color: var(--ink, #1A2820);
    width: 232px;
    background: var(--bg, #FFF8F0);
    border: 1px solid var(--rule, rgba(26, 40, 32, 0.12));
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 6px 18px rgba(26, 40, 32, 0.16);
  }
  .popup-card .popup-main {
    display: block;
    color: inherit;
    text-decoration: none;
    outline: none;
    -webkit-tap-highlight-color: transparent;
  }
  .popup-card .popup-main:focus { outline: none; }
  .popup-card .popup-photo {
    position: relative;
    width: 100%;
    aspect-ratio: 16 / 10;
    background-size: cover;
    background-position: center;
    background-color: var(--paper, #FDF3E2);
  }
  .popup-card .popup-close {
    position: absolute;
    top: 8px;
    right: 8px;
    width: 28px;
    height: 28px;
    border-radius: 50%;
    border: 0;
    background: rgba(255, 248, 240, 0.95);
    color: var(--ink, #1A2820);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 1px 4px rgba(26, 40, 32, 0.3);
    padding: 0;
    transition: background 0.1s, transform 0.1s;
  }
  .popup-card .popup-close:hover { background: #FFF8F0; }
  .popup-card .popup-close:active { transform: scale(0.94); }
  .popup-card .popup-photo.no-photo {
    background-image: repeating-linear-gradient(
      135deg,
      var(--paper, #FDF3E2) 0,
      var(--paper, #FDF3E2) 8px,
      rgba(26, 40, 32, 0.04) 8px,
      rgba(26, 40, 32, 0.04) 16px
    );
  }
  .popup-card .popup-info {
    padding: 0.55rem 0.75rem 0.4rem;
  }
  .popup-card .popup-title-row {
    display: flex;
    align-items: baseline;
    gap: 0.5rem;
    min-width: 0;
  }
  .popup-card .popup-name {
    font-family: var(--serif, Georgia, serif);
    font-style: italic;
    font-weight: 500;
    font-size: 1.0625rem;
    line-height: 1.2;
    letter-spacing: -0.01em;
    color: var(--ink, #1A2820);
    flex: 1 1 auto;
    min-width: 0;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .popup-card .popup-rating {
    font-family: var(--serif, Georgia, serif);
    font-size: 1rem;
    font-weight: 600;
    color: var(--terracotta, #B8543A);
    line-height: 1;
    flex: 0 0 auto;
  }
  .popup-card .popup-rating span {
    font-size: 0.6875rem;
    color: var(--muted, rgba(26, 40, 32, 0.6));
    font-weight: 400;
    margin-left: 0.05rem;
  }
  .popup-card .popup-status {
    font-family: var(--sans, system-ui, sans-serif);
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    flex: 0 0 auto;
  }
  .popup-card .popup-status.visited { color: var(--terracotta, #B8543A); }
  .popup-card .popup-status.wishlist { color: var(--forest-soft, #2D4538); }
  .popup-card .popup-meta {
    font-family: var(--sans, system-ui, sans-serif);
    font-size: 0.75rem;
    color: var(--muted, rgba(26, 40, 32, 0.6));
    margin-top: 0.2rem;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }
  .popup-card .popup-maps-btn {
    display: block;
    margin: 0 0.5rem 0.55rem;
    padding: 0.55rem 0.75rem;
    border-radius: 999px;
    background: var(--ink, #1A2820);
    color: var(--bg, #FFF8F0);
    font-family: var(--sans, system-ui, sans-serif);
    font-size: 0.8125rem;
    font-weight: 500;
    text-align: center;
    text-decoration: none;
    transition: background 0.1s;
  }
  .popup-card .popup-maps-btn:hover { background: var(--forest-soft, #2D4538); }
  @media (max-width: 600px) {
    .popup-card { width: 196px; }
    .popup-card .popup-info { padding: 0.5rem 0.625rem 0.35rem; }
    .popup-card .popup-name { font-size: 0.9375rem; }
    .popup-card .popup-rating { font-size: 0.9375rem; }
    .popup-card .popup-meta { font-size: 0.6875rem; }
    .popup-card .popup-maps-btn {
      margin: 0 0.4rem 0.45rem;
      padding: 0.45rem 0.6rem;
      font-size: 0.75rem;
    }
  }
</style>

<style>
  .map-wrap { width: 100%; }
  .map-shell {
    position: relative;
    width: 100%;
  }
  .gmap-host {
    width: 100%;
    height: clamp(480px, 72vh, 760px);
    border-radius: 12px;
    border: 1px solid var(--rule);
    background: var(--bg);
    overflow: hidden;
  }
  .map-empty {
    text-align: center;
    padding: 4rem 1rem;
    color: var(--muted);
  }
  .map-empty p { margin: 0 0 0.5rem; }
  .map-missing {
    color: var(--muted);
    font-size: 0.8125rem;
    margin: 0.75rem 0 0;
    text-align: center;
  }
  .map-fail {
    padding: 2rem;
    text-align: center;
    color: var(--muted);
    font-size: 0.9375rem;
  }

  /* Legend overlay — top-left of the map */
  .map-legend {
    position: absolute;
    top: 12px;
    left: 12px;
    background: rgba(255, 248, 240, 0.96);
    backdrop-filter: blur(6px);
    -webkit-backdrop-filter: blur(6px);
    border: 1px solid var(--rule);
    border-radius: 10px;
    padding: 0.55rem 0.75rem;
    font-family: var(--sans);
    font-size: 0.8125rem;
    color: var(--ink);
    box-shadow: 0 2px 8px rgba(26, 40, 32, 0.08);
    z-index: 5;
    pointer-events: none;
  }
  .legend-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    line-height: 1.4;
  }
  .legend-row + .legend-row { margin-top: 0.2rem; }
  .dot {
    display: inline-block;
    width: 10px;
    height: 10px;
    border-radius: 50%;
    border: 2px solid #FFF8F0;
    box-shadow: 0 0 0 1px rgba(26, 40, 32, 0.15);
  }
  .dot-visited { background: var(--terracotta); }
  .dot-wishlist { background: var(--forest-soft); }

  /* Locate button — bottom-right of the map */
  .locate-btn {
    position: absolute;
    bottom: 28px;
    right: 12px;
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--bg);
    border: 1px solid var(--rule);
    color: var(--ink);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(26, 40, 32, 0.12);
    transition: background 0.1s, color 0.1s, transform 0.1s;
    z-index: 5;
  }
  .locate-btn:hover {
    background: var(--ink);
    color: var(--bg);
  }
  .locate-btn:active { transform: scale(0.96); }
  .locate-btn.is-busy { opacity: 0.6; cursor: wait; }
  .locate-btn.is-busy svg { animation: locate-spin 1s linear infinite; }
  @keyframes locate-spin { to { transform: rotate(360deg); } }

  @media (max-width: 600px) {
    .gmap-host { height: clamp(400px, 65vh, 600px); }
    .map-legend { font-size: 0.75rem; padding: 0.45rem 0.6rem; }
    .locate-btn { bottom: 80px; right: 8px; }
  }
</style>

---
import type { Filters, Location, Tag } from '../lib/types';
import { REGIONS, type Region } from '../lib/regions';

interface Props {
  filters: Filters;
  locations: Location[];
  regions?: Region[];
  tags: Tag[];
  cuisines: string[];
  /**
   * Current view mode on /all. When "map", a hidden `view` input is added so
   * form submissions preserve the map view instead of falling back to list.
   */
  view?: 'list' | 'map';
}
const { filters, locations, regions = REGIONS, tags, cuisines, view = 'list' } = Astro.props;
const clearAllHref = view === 'map' ? '/all?view=map' : '/all';

const vibes = tags.filter((t) => t.category === 'vibe');
const isOn = (arr: string[] | undefined, v: string) => (arr ?? []).includes(v);

const sort = filters.sort ?? 'name';
const sortLabels: Record<string, string> = {
  rating: 'Best first',
  recent: 'Recently visited',
  name: 'A→Z',
};

const TOP_RATED_THRESHOLD = 7;
const topRated = filters.minRating != null && filters.minRating >= TOP_RATED_THRESHOLD;

const PRICE_TIERS: { tier: number; symbol: string; range: string }[] = [
  { tier: 1, symbol: '$', range: 'under $20pp' },
  { tier: 2, symbol: '$$', range: '$20–40pp' },
  { tier: 3, symbol: '$$$', range: '$40–80pp' },
  { tier: 4, symbol: '$$$$', range: '$80–150pp' },
  { tier: 5, symbol: '$$$$$', range: '$150+pp' },
];

// Desktop dropdowns are single-select; pick the first selected value if any.
const selectedCuisine = filters.cuisines?.[0] ?? '';
const selectedRegion = filters.regions?.[0] ?? '';
const selectedSuburb = filters.locations?.[0] ?? '';

const locationValue = selectedRegion ? `region:${selectedRegion}` : selectedSuburb;
const locationLabel = (() => {
  if (selectedRegion) {
    return REGIONS.find((r) => r.slug === selectedRegion)?.name ?? selectedRegion;
  }
  if (selectedSuburb) {
    return locations.find((l) => l.slug === selectedSuburb)?.name ?? selectedSuburb;
  }
  return 'Anywhere';
})();

const hasFilters = !!(
  (filters.cuisines && filters.cuisines.length) ||
  (filters.locations && filters.locations.length) ||
  (filters.regions && filters.regions.length) ||
  topRated ||
  (filters.vibes && filters.vibes.length) ||
  (filters.price && filters.price.length)
);

interface Chip {
  key: string;
  label: string;
  removeName: string;
  removeValue?: string;
}
const activeChips: Chip[] = [];
for (const c of filters.cuisines ?? []) {
  activeChips.push({ key: `cu-${c}`, label: c, removeName: 'cuisine', removeValue: c });
}
for (const slug of filters.regions ?? []) {
  const rname = REGIONS.find((r) => r.slug === slug)?.name ?? slug;
  activeChips.push({ key: `rg-${slug}`, label: rname, removeName: 'location', removeValue: `region:${slug}` });
}
for (const slug of filters.locations ?? []) {
  const lname = locations.find((l) => l.slug === slug)?.name ?? slug;
  activeChips.push({ key: `su-${slug}`, label: lname, removeName: 'location', removeValue: slug });
}
if (topRated) activeChips.push({ key: 'tr', label: `Top rated (${TOP_RATED_THRESHOLD}+)`, removeName: 'minRating' });
for (const slug of filters.vibes ?? []) {
  const t = vibes.find((x) => x.slug === slug);
  if (t) activeChips.push({ key: `v-${slug}`, label: t.label, removeName: 'vibes', removeValue: slug });
}
for (const tier of filters.price ?? []) {
  const p = PRICE_TIERS.find((x) => x.tier === tier);
  if (p) activeChips.push({ key: `p-${tier}`, label: `${p.symbol} ${p.range}`, removeName: 'price', removeValue: String(tier) });
}
---
<form class="filter-bar" method="get" action="/all">
  {/* Preserve the active view (map/list) when submitting filters — without
      this, the GET form rebuilds the query string from form fields only and
      the user gets bounced back to list view. */}
  {view === 'map' && <input type="hidden" name="view" value="map" />}
  <div class="bar-inner">
    {/* Row 1: search + main pills (cuisine, location, sort, top-rated) */}
    <div class="primary-row">
      <div class="search-input-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" />
          <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <input
          type="search"
          name="q"
          value={filters.q ?? ''}
          placeholder="Search places, dishes, suburbs…"
          enterkeyhint="search"
          autocomplete="off"
        />
      </div>
      <div class="pill-select" data-name="cuisine">
        <input type="hidden" name="cuisine" value={selectedCuisine} />
        <button type="button" class:list={['pill', { on: !!selectedCuisine }]} data-pill-trigger>
          <span class="meta">Cuisine</span>
          <span class="label">{selectedCuisine || 'Any'}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          {selectedCuisine && (
            <button type="button" class="opt clear" data-value="">Clear</button>
          )}
          {cuisines.map((c) => (
            <button
              type="button"
              class:list={['opt', { on: selectedCuisine === c }]}
              data-value={c}
            >
              {c}
            </button>
          ))}
        </div>
      </div>

      <div class="pill-select" data-name="location">
        <input type="hidden" name="location" value={locationValue} />
        <button type="button" class:list={['pill', { on: !!locationValue }]} data-pill-trigger>
          <span class="meta">Location</span>
          <span class="label">{locationLabel}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          {locationValue && (
            <button type="button" class="opt clear" data-value="">Clear</button>
          )}
          <div class="opt-group-label">Regions</div>
          {regions.map((r) => (
            <button
              type="button"
              class:list={['opt', { on: locationValue === `region:${r.slug}` }]}
              data-value={`region:${r.slug}`}
            >
              {r.name}
            </button>
          ))}
          <div class="opt-group-label">Suburbs</div>
          {locations.map((l) => (
            <button
              type="button"
              class:list={['opt', { on: locationValue === l.slug }]}
              data-value={l.slug}
            >
              {l.name}
            </button>
          ))}
        </div>
      </div>

      <div class="pill-select" data-name="sort">
        <input type="hidden" name="sort" value={sort === 'name' ? '' : sort} />
        <button type="button" class:list={['pill', { on: sort !== 'name' }]} data-pill-trigger>
          <span class="meta">Sort</span>
          <span class="label">{sortLabels[sort]}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          <button type="button" class:list={['opt', { on: sort === 'name' }]} data-value="">A to Z</button>
          <button type="button" class:list={['opt', { on: sort === 'rating' }]} data-value="rating">Best first</button>
          <button type="button" class:list={['opt', { on: sort === 'recent' }]} data-value="recent">Recently visited</button>
        </div>
      </div>

      <div class="toggle-wrap">
        <input type="hidden" name="minRating" value={topRated ? String(TOP_RATED_THRESHOLD) : ''} />
        <button
          type="button"
          class:list={['pill', 'toggle', { on: topRated }]}
          data-top-rated
          aria-pressed={topRated ? 'true' : 'false'}
        >
          <span class="check" aria-hidden="true">{topRated ? '✓' : ''}</span>
          Top rated ({TOP_RATED_THRESHOLD}+)
        </button>
      </div>
    </div>

    {/* Row 2: price chips */}
    <div class="chip-row">
      <span class="row-label">Price</span>
      {PRICE_TIERS.map((p) => (
        <label class:list={['price-chip', { on: (filters.price ?? []).includes(p.tier) }]}>
          <input
            type="checkbox"
            name="price"
            value={p.tier}
            checked={(filters.price ?? []).includes(p.tier)}
          />
          <span class="symbol">{p.symbol}</span>
          <span class="range">{p.range}</span>
        </label>
      ))}
    </div>

    {/* Row 3: vibe chips on their own row */}
    {vibes.length > 0 && (
      <div class="chip-row">
        <span class="row-label">Vibe</span>
        {vibes.map((t) => (
          <label class:list={['vibe-chip', { on: isOn(filters.vibes, t.slug) }]}>
            <input
              type="checkbox"
              name="vibes"
              value={t.slug}
              checked={isOn(filters.vibes, t.slug)}
            />
            {t.label}
          </label>
        ))}
      </div>
    )}

    {activeChips.length > 0 && (
      <div class="active-row">
        <span class="row-label applied">Applied</span>
        {activeChips.map((chip) => (
          <button
            type="button"
            class="active-chip"
            data-remove-name={chip.removeName}
            data-remove-value={chip.removeValue ?? ''}
          >
            {chip.label}
            <span class="x" aria-hidden="true">×</span>
          </button>
        ))}
        {hasFilters && (
          <a href={clearAllHref} class="clear-all">Clear all</a>
        )}
      </div>
    )}
  </div>

  <noscript>
    <button type="submit" class="apply-fallback">Apply filters</button>
  </noscript>
</form>

<script>
  // Same View Transitions caveat as MobileFilterSheet: the site uses
  // <ClientRouter />, so the DOM is swapped on navigation. Per-element
  // listeners must be re-attached on every astro:page-load. The single
  // document-level "close panels on outside click" listener is attached
  // once, outside the per-page init.

  document.addEventListener('click', () => {
    const form = document.querySelector<HTMLFormElement>('.filter-bar');
    if (!form) return;
    form.querySelectorAll<HTMLDivElement>('.pill-select .panel').forEach((p) => {
      p.hidden = true;
    });
  });

  function initFilterBar() {
    const form = document.querySelector<HTMLFormElement>('.filter-bar');
    if (!form) return;
    const submitNow = () => form.submit();

    const pillSelects = form.querySelectorAll<HTMLDivElement>('.pill-select');
    const closeAllPanels = () => {
      pillSelects.forEach((sel) => {
        const panel = sel.querySelector<HTMLDivElement>('.panel');
        if (panel) panel.hidden = true;
      });
    };
    pillSelects.forEach((sel) => {
      const trigger = sel.querySelector<HTMLButtonElement>('[data-pill-trigger]');
      const panel = sel.querySelector<HTMLDivElement>('.panel');
      const hidden = sel.querySelector<HTMLInputElement>('input[type="hidden"]');
      if (!trigger || !panel || !hidden) return;
      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = !panel.hidden;
        closeAllPanels();
        panel.hidden = wasOpen;
      });
      panel.querySelectorAll<HTMLButtonElement>('.opt').forEach((opt) => {
        opt.addEventListener('click', (e) => {
          e.stopPropagation();
          hidden.value = opt.dataset.value ?? '';
          panel.hidden = true;
          submitNow();
        });
      });
    });

    const topRatedBtn = form.querySelector<HTMLButtonElement>('[data-top-rated]');
    const topRatedHidden = form.querySelector<HTMLInputElement>('input[name="minRating"]');
    if (topRatedBtn && topRatedHidden) {
      topRatedBtn.addEventListener('click', () => {
        topRatedHidden.value = topRatedHidden.value ? '' : '7';
        submitNow();
      });
    }

    form.querySelectorAll<HTMLInputElement>('.vibe-chip input, .price-chip input').forEach((cb) => {
      cb.addEventListener('change', submitNow);
    });

    form.querySelectorAll<HTMLButtonElement>('.active-chip').forEach((chip) => {
      chip.addEventListener('click', () => {
        const name = chip.dataset.removeName;
        const value = chip.dataset.removeValue;
        if (!name) return;
        if ((name === 'vibes' || name === 'price') && value) {
          const cb = form.querySelector<HTMLInputElement>(`input[name="${name}"][value="${value}"]`);
          if (cb) cb.checked = false;
        } else {
          const input = form.querySelector<HTMLInputElement>(`input[name="${name}"]`);
          if (input) input.value = '';
        }
        submitNow();
      });
    });
  }

  // Fires on initial load and after every View Transitions swap.
  document.addEventListener('astro:page-load', initFilterBar);
</script>

<style>
  /* Desktop search input. Lives inside .primary-row alongside the filter pills.
     Submits via Enter (native form submit), preserving every other applied
     filter via the form's existing hidden inputs. */
  .search-input-wrap {
    position: relative;
  }
  .search-icon {
    position: absolute;
    left: 0.85rem;
    top: 50%;
    transform: translateY(-50%);
    color: var(--muted);
    pointer-events: none;
  }
  .search-input-wrap input[type="search"] {
    width: 100%;
    height: 40px;
    padding: 0 0.95rem 0 2.2rem;
    border: 1px solid var(--rule);
    border-radius: 999px;
    background: var(--bg);
    color: var(--ink);
    font-family: var(--sans);
    font-size: 0.9rem;
    outline: none;
    -webkit-appearance: none;
    appearance: none;
    transition: border-color 0.1s;
  }
  .search-input-wrap input[type="search"]::placeholder { color: var(--muted); }
  .search-input-wrap input[type="search"]:focus { border-color: var(--ink); }
  .search-input-wrap input[type="search"]::-webkit-search-cancel-button {
    -webkit-appearance: none;
  }

  .filter-bar {
    background: var(--paper);
    border-top: 1px solid var(--rule);
    border-bottom: 1px solid var(--rule);
    padding: 1.25rem 1.5rem;
    font-family: var(--sans);
  }
  .bar-inner {
    max-width: 1280px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 0.875rem;
  }
  @media (max-width: 640px) {
    .filter-bar { padding: 0.875rem 1rem; }
  }

  /* Primary row — search input + main filter pills, all in one flex line.
     Wraps gracefully on narrow viewports; on desktop it sits on a single row. */
  .primary-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: stretch;
  }
  .primary-row .search-input-wrap {
    flex: 1 1 18rem;
    min-width: 14rem;
    max-width: 28rem;
  }
  /* Old .top-row class retained in case any other consumer references it; the
     filter bar itself no longer renders one. */
  .top-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.625rem;
    align-items: stretch;
  }

  /* Pill button (used by selects + toggle) */
  .pill {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    border: 1px solid var(--rule-strong);
    background: var(--bg);
    color: var(--ink);
    border-radius: 12px;
    padding: 0.5rem 0.85rem 0.5rem 1rem;
    font-family: var(--sans);
    font-size: 0.875rem;
    font-weight: 500;
    cursor: pointer;
    outline: none;
    white-space: nowrap;
    transition: border-color 0.1s, background 0.1s, color 0.1s;
    min-height: 44px;
  }
  .pill:hover { border-color: var(--ink); }
  .pill .meta {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.06em;
    color: var(--muted);
    text-transform: uppercase;
  }
  .pill .label { font-weight: 500; }
  .pill.on {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .pill.on .meta { color: rgba(255, 255, 255, 0.7); }
  .pill .caret {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 18px;
    height: 18px;
    border-radius: 50%;
    background: rgba(26, 40, 32, 0.06);
    color: var(--ink);
  }
  .pill.on .caret {
    background: rgba(255, 255, 255, 0.18);
    color: var(--bg);
  }

  /* Pill select dropdown */
  .pill-select { position: relative; }
  .panel {
    position: absolute;
    top: calc(100% + 6px);
    left: 0;
    z-index: 20;
    background: var(--bg);
    border: 1px solid var(--rule);
    border-radius: 12px;
    box-shadow: 0 12px 32px rgba(26, 40, 32, 0.12);
    min-width: 240px;
    max-height: 360px;
    overflow-y: auto;
    padding: 0.25rem 0;
  }
  .opt {
    display: block;
    width: 100%;
    text-align: left;
    padding: 0.55rem 0.875rem;
    border: none;
    background: transparent;
    font-family: var(--sans);
    font-size: 0.875rem;
    color: var(--ink);
    cursor: pointer;
  }
  .opt:hover { background: var(--paper); }
  .opt.on { background: var(--paper); font-weight: 600; }
  .opt.clear {
    color: var(--muted);
    border-bottom: 1px solid var(--rule);
    margin-bottom: 0.25rem;
  }
  .opt-group-label {
    padding: 0.5rem 0.875rem 0.25rem;
    font-size: 0.6875rem;
    letter-spacing: 0.12em;
    font-weight: 600;
    color: var(--muted);
    text-transform: uppercase;
  }

  /* Top rated toggle */
  .pill.toggle {
    padding-left: 0.875rem;
  }
  .pill.toggle .check {
    width: 16px;
    height: 16px;
    border-radius: 4px;
    border: 1.5px solid var(--rule-strong);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    font-size: 0.7rem;
    line-height: 1;
    color: transparent;
  }
  .pill.toggle.on .check {
    border-color: var(--bg);
    background: var(--bg);
    color: var(--ink);
    font-weight: 700;
  }

  /* Chip rows (price, vibes) */
  .chip-row, .active-row {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
  }
  .row-label {
    font-size: 0.6875rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    margin-right: 0.25rem;
  }
  .row-label.applied { color: var(--forest-soft); }
  .vibe-chip, .price-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    border: 1px solid var(--rule);
    background: var(--bg);
    color: var(--ink);
    border-radius: 999px;
    padding: 0.4rem 0.85rem;
    font-size: 0.8125rem;
    font-weight: 500;
    cursor: pointer;
    user-select: none;
    transition: border-color 0.1s, background 0.1s, color 0.1s;
  }
  .vibe-chip:hover, .price-chip:hover { border-color: var(--rule-strong); }
  .vibe-chip.on {
    background: var(--terracotta);
    color: var(--bg);
    border-color: var(--terracotta);
  }
  .price-chip .symbol {
    font-weight: 700;
    font-variant-numeric: tabular-nums;
  }
  .price-chip .range {
    color: var(--muted);
    font-size: 0.75rem;
    font-weight: 400;
  }
  .price-chip.on {
    background: var(--ink);
    color: var(--bg);
    border-color: var(--ink);
  }
  .price-chip.on .range { color: rgba(255, 255, 255, 0.7); }
  .vibe-chip input, .price-chip input { display: none; }

  /* Active chips row */
  .active-row {
    padding-top: 0.75rem;
    border-top: 1px dashed var(--rule);
  }
  .active-chip {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    border: 1px solid var(--ink);
    background: var(--bg);
    color: var(--ink);
    border-radius: 999px;
    padding: 0.25rem 0.375rem 0.25rem 0.75rem;
    font-family: var(--sans);
    font-size: 0.75rem;
    font-weight: 500;
    cursor: pointer;
  }
  .active-chip .x {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 16px;
    height: 16px;
    border-radius: 50%;
    background: var(--ink);
    color: var(--bg);
    font-size: 0.625rem;
    line-height: 1;
  }
  .clear-all {
    color: var(--terracotta);
    font-size: 0.75rem;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 1px solid var(--terracotta);
    padding: 0.25rem 0;
    margin-left: 0.25rem;
  }

  .apply-fallback {
    margin-top: 0.75rem;
    padding: 0.6rem 1.3rem;
    background: var(--ink);
    color: var(--bg);
    border: none;
    border-radius: 999px;
    cursor: pointer;
    font-family: var(--sans);
    font-size: 0.875rem;
  }
</style>

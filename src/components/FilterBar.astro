---
import type { Filters, Location, Tag } from '../lib/types';
import { REGIONS, type Region } from '../lib/regions';

interface Props {
  filters: Filters;
  locations: Location[];
  regions?: Region[];
  tags: Tag[];
  cuisines: string[];
  /**
   * Current view mode on /all. When "map", a hidden `view` input is added so
   * form submissions preserve the map view instead of falling back to list.
   */
  view?: 'list' | 'map';
}
const { filters, locations, regions = REGIONS, tags, cuisines, view = 'list' } = Astro.props;
// `view` prop kept on the interface so the page can pass it down for parity
// with MobileFilterSheet, even though desktop no longer needs to thread it
// into form state — every change goes through URL replaceState now.
void view;

const vibes = tags.filter((t) => t.category === 'vibe');
const isOn = (arr: string[] | undefined, v: string) => (arr ?? []).includes(v);

const sort = filters.sort ?? 'name';
const sortLabels: Record<string, string> = {
  rating: 'Best first',
  recent: 'Recently visited',
  name: 'A→Z',
};

const TOP_RATED_THRESHOLD = 7;
const topRated = filters.minRating != null && filters.minRating >= TOP_RATED_THRESHOLD;

// Mirrors the canonical ranges in src/components/admin/RestaurantForm.astro
// and UnifiedEntryForm.astro — keep these in sync with the admin entry form.
const PRICE_TIERS: { tier: number; symbol: string; range: string }[] = [
  { tier: 1, symbol: '$', range: '$0–20' },
  { tier: 2, symbol: '$$', range: '$20–50' },
  { tier: 3, symbol: '$$$', range: '$50–100' },
  { tier: 4, symbol: '$$$$', range: '$100–200' },
  { tier: 5, symbol: '$$$$$', range: '$200+' },
];

// Cuisine and Location pills are multi-select. The pill's display label
// shows "Any" / "Anywhere" when nothing's picked, the single value when
// exactly one is picked, and "N selected" otherwise. Specific selections
// always appear in the .active-row chip strip below for clarity.
const selectedCuisines = filters.cuisines ?? [];
const selectedRegionSlugs = filters.regions ?? [];
const selectedSuburbSlugs = filters.locations ?? [];
const totalLocations = selectedRegionSlugs.length + selectedSuburbSlugs.length;

const cuisineLabel = (() => {
  if (selectedCuisines.length === 0) return 'Any';
  if (selectedCuisines.length === 1) return selectedCuisines[0];
  return `${selectedCuisines.length} selected`;
})();
const locationLabel = (() => {
  if (totalLocations === 0) return 'Anywhere';
  if (totalLocations === 1) {
    if (selectedRegionSlugs.length === 1) {
      const slug = selectedRegionSlugs[0];
      return REGIONS.find((r) => r.slug === slug)?.name ?? slug;
    }
    const slug = selectedSuburbSlugs[0];
    return locations.find((l) => l.slug === slug)?.name ?? slug;
  }
  return `${totalLocations} selected`;
})();

const visitedLabels: Record<string, string> = {
  '': 'All',
  yes: 'Visited',
  no: 'On the list',
};
const visitedKey = filters.visited ?? '';
const visitedLabel = visitedLabels[visitedKey] ?? 'All';

const TAG_CHIP_LIMIT = 999; // no truncation

// Active-row chip data — only surfaces multi-select state for cuisine and
// location (the two pills whose label collapses to "N selected" when more
// than one is picked). Single-pick values live inside the pill label.
// Other filters (vibes, price, visited, top-rated) have their own visible
// controls, so they never appear in the Applied strip.
interface Chip {
  key: string;
  label: string;
  removeName: string;
  removeValue?: string;
}
const activeChips: Chip[] = [];
const cuisineCount = selectedCuisines.length;
const locationCount = totalLocations;
if (cuisineCount >= 2) {
  for (const c of selectedCuisines) {
    activeChips.push({ key: `cu-${c}`, label: c, removeName: 'cuisine', removeValue: c });
  }
}
if (locationCount >= 2) {
  for (const slug of selectedRegionSlugs) {
    const rname = REGIONS.find((r) => r.slug === slug)?.name ?? slug;
    activeChips.push({ key: `rg-${slug}`, label: rname, removeName: 'location', removeValue: `region:${slug}` });
  }
  for (const slug of selectedSuburbSlugs) {
    const lname = locations.find((l) => l.slug === slug)?.name ?? slug;
    activeChips.push({ key: `su-${slug}`, label: lname, removeName: 'location', removeValue: slug });
  }
}
// "Has any filter at all" — drives whether to show the Applied row's
// Clear all link. Broader than activeChips.length because Clear all
// should be visible even when only a single-pick filter (1 cuisine,
// just top-rated, just a vibe) is active.
const anyFilterActive = !!(
  selectedCuisines.length ||
  selectedRegionSlugs.length ||
  selectedSuburbSlugs.length ||
  topRated ||
  visitedKey ||
  (filters.vibes && filters.vibes.length) ||
  (filters.price && filters.price.length) ||
  (filters.q && filters.q.trim()) ||
  (filters.sort && filters.sort !== 'name')
);
const hasFilters = activeChips.length > 0;
void TAG_CHIP_LIMIT;
---
<form class="filter-bar" method="get" action="/all">
  {/* Preserve the active view (map/list) when submitting filters — without
      this, the GET form rebuilds the query string from form fields only and
      the user gets bounced back to list view. */}
  {view === 'map' && <input type="hidden" name="view" value="map" />}
  <div class="bar-inner">
    {/* Row 1: search + main pills (cuisine, location, sort, top-rated) */}
    <div class="primary-row">
      <div class="search-input-wrap">
        <svg class="search-icon" width="14" height="14" viewBox="0 0 16 16" fill="none" aria-hidden="true">
          <circle cx="7" cy="7" r="5" stroke="currentColor" stroke-width="1.5" />
          <path d="M11 11l3.5 3.5" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
        </svg>
        <input
          type="search"
          name="q"
          value={filters.q ?? ''}
          placeholder="Try “date night italian surry hills”…"
          enterkeyhint="search"
          autocomplete="off"
        />
        <button type="button" class="search-clear" data-search-clear hidden aria-label="Clear search">
          <svg width="14" height="14" viewBox="0 0 14 14" aria-hidden="true">
            <path d="M2 2 L12 12 M12 2 L2 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
      </div>
      <div class="pill-select" data-name="cuisine" data-multi>
        <button type="button" class:list={['pill', { on: selectedCuisines.length > 0 }]} data-pill-trigger>
          <span class="meta">Cuisine</span>
          <span class="label" data-pill-label>{cuisineLabel}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          <button type="button" class="opt opt-clear" data-clear-this hidden={selectedCuisines.length === 0}>Clear all</button>
          {cuisines.map((c) => (
            <button
              type="button"
              class:list={['opt', 'opt-multi', { on: selectedCuisines.includes(c) }]}
              data-multi-value={c}
              role="checkbox"
              aria-checked={selectedCuisines.includes(c) ? 'true' : 'false'}
            >
              <span class="opt-tick" aria-hidden="true">✓</span>
              <span>{c}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="pill-select" data-name="location" data-multi>
        <button type="button" class:list={['pill', { on: totalLocations > 0 }]} data-pill-trigger>
          <span class="meta">Location</span>
          <span class="label" data-pill-label>{locationLabel}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          <button type="button" class="opt opt-clear" data-clear-this hidden={totalLocations === 0}>Clear all</button>
          <div class="opt-group-label">Regions</div>
          {regions.map((r) => (
            <button
              type="button"
              class:list={['opt', 'opt-multi', { on: selectedRegionSlugs.includes(r.slug) }]}
              data-multi-value={`region:${r.slug}`}
              role="checkbox"
              aria-checked={selectedRegionSlugs.includes(r.slug) ? 'true' : 'false'}
            >
              <span class="opt-tick" aria-hidden="true">✓</span>
              <span>{r.name}</span>
            </button>
          ))}
          <div class="opt-group-label">Suburbs</div>
          {locations.map((l) => (
            <button
              type="button"
              class:list={['opt', 'opt-multi', { on: selectedSuburbSlugs.includes(l.slug) }]}
              data-multi-value={l.slug}
              role="checkbox"
              aria-checked={selectedSuburbSlugs.includes(l.slug) ? 'true' : 'false'}
            >
              <span class="opt-tick" aria-hidden="true">✓</span>
              <span>{l.name}</span>
            </button>
          ))}
        </div>
      </div>

      <div class="pill-select" data-name="visited">
        <button type="button" class:list={['pill', { on: !!visitedKey }]} data-pill-trigger>
          <span class="meta">Status</span>
          <span class="label" data-pill-label>{visitedLabel}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          <button type="button" class:list={['opt', { on: visitedKey === '' }]} data-value="">All</button>
          <button type="button" class:list={['opt', { on: visitedKey === 'yes' }]} data-value="yes">Visited</button>
          <button type="button" class:list={['opt', { on: visitedKey === 'no' }]} data-value="no">On the list</button>
        </div>
      </div>

      <div class="pill-select" data-name="sort">
        <input type="hidden" name="sort" value={sort === 'name' ? '' : sort} />
        <button type="button" class:list={['pill', { on: sort !== 'name' }]} data-pill-trigger>
          <span class="meta">Sort</span>
          <span class="label">{sortLabels[sort]}</span>
          <span class="caret" aria-hidden="true">
            <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
              <path d="M3 4.5L6 7.5L9 4.5" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </button>
        <div class="panel" hidden>
          <button type="button" class:list={['opt', { on: sort === 'name' }]} data-value="">A to Z</button>
          <button type="button" class:list={['opt', { on: sort === 'rating' }]} data-value="rating">Best first</button>
          <button type="button" class:list={['opt', { on: sort === 'recent' }]} data-value="recent">Recently visited</button>
        </div>
      </div>

      <div class="toggle-wrap">
        <input type="hidden" name="minRating" value={topRated ? String(TOP_RATED_THRESHOLD) : ''} />
        <button
          type="button"
          class:list={['pill', 'toggle', { on: topRated }]}
          data-top-rated
          aria-pressed={topRated ? 'true' : 'false'}
        >
          <span class="check" aria-hidden="true">{topRated ? '✓' : ''}</span>
          Top rated ({TOP_RATED_THRESHOLD}+)
        </button>
      </div>
    </div>

    {/* Row 2: price chips */}
    <div class="chip-row">
      <span class="row-label">Price</span>
      {PRICE_TIERS.map((p) => (
        <label class:list={['price-chip', { on: (filters.price ?? []).includes(p.tier) }]}>
          <input
            type="checkbox"
            name="price"
            value={p.tier}
            checked={(filters.price ?? []).includes(p.tier)}
          />
          <span class="symbol">{p.symbol}</span>
          <span class="range">{p.range}</span>
        </label>
      ))}
    </div>

    {/* Row 3: vibe chips on their own row */}
    {vibes.length > 0 && (
      <div class="chip-row">
        <span class="row-label">Vibe</span>
        {vibes.map((t) => (
          <label class:list={['vibe-chip', { on: isOn(filters.vibes, t.slug) }]}>
            <input
              type="checkbox"
              name="vibes"
              value={t.slug}
              checked={isOn(filters.vibes, t.slug)}
            />
            {t.label}
          </label>
        ))}
      </div>
    )}

    {/* Active filters strip. Always rendered (display: none when no
        filters anywhere) so the client filter engine has a stable target.
        Chips only appear when 2+ multi-select values exist for cuisine/
        location; "Clear all" appears whenever ANY filter is active so
        the user always has a reset path. */}
    <div class="active-row" style={anyFilterActive ? '' : 'display: none'}>
      {hasFilters && <span class="row-label applied">Applied</span>}
      {activeChips.map((chip) => (
        <button
          type="button"
          class="active-chip"
          data-remove-name={chip.removeName}
          data-remove-value={chip.removeValue ?? ''}
        >
          {chip.label}
          <span class="x" aria-hidden="true">×</span>
        </button>
      ))}
      {anyFilterActive && (
        <a href={view === 'map' ? '/all?view=map' : '/all'} class="clear-all" data-clear-all>Clear all filters</a>
      )}
    </div>
  </div>

  <noscript>
    <button type="submit" class="apply-fallback">Apply filters</button>
  </noscript>
</form>

<script>
  import { smartParse, type SmartParseRefData, type SmartParseResult } from '../lib/smart-parse';

  // Module-scoped: remembers the last batch of filters smart-parse added
  // so that clearing the search input can undo exactly that batch (and
  // not, for example, a cuisine the user picked manually via the pill).
  let lastSmartParse: SmartParseResult | null = null;

  // Same View Transitions caveat as MobileFilterSheet: the site uses
  // <ClientRouter />, so the DOM is swapped on navigation. Per-element
  // listeners must be re-attached on every astro:page-load. The single
  // document-level "close panels on outside click" listener is attached
  // once, outside the per-page init.

  document.addEventListener('click', () => {
    const form = document.querySelector<HTMLFormElement>('.filter-bar');
    if (!form) return;
    form.querySelectorAll<HTMLDivElement>('.pill-select .panel').forEach((p) => {
      p.hidden = true;
    });
  });

  // URL-state updaters. The /all page's filter engine listens for the
  // 'lucaseats:filters-changed' event and re-applies from the URL — so
  // every filter UI mutation just needs to update the URL and dispatch.
  function dispatchFiltersChanged() {
    window.dispatchEvent(new CustomEvent('lucaseats:filters-changed'));
  }
  function setSingleParam(name: string, value: string) {
    const url = new URL(window.location.href);
    url.searchParams.delete(name);
    if (value) url.searchParams.append(name, value);
    window.history.replaceState({}, '', url.toString());
    dispatchFiltersChanged();
  }
  function toggleMultiParam(name: string, value: string, checked: boolean) {
    const url = new URL(window.location.href);
    const all = url.searchParams.getAll(name);
    url.searchParams.delete(name);
    const next = checked
      ? [...all.filter((v) => v !== value), value]
      : all.filter((v) => v !== value);
    for (const v of next) url.searchParams.append(name, v);
    window.history.replaceState({}, '', url.toString());
    dispatchFiltersChanged();
  }

  /**
   * Wipe every filter param from the URL — manual picks AND smart-parse
   * additions. Preserves `view` (list/map) since that's UI state, not a
   * filter. Triggered by the search-input × button (per the spec, that
   * button means "fresh start").
   */
  function clearAllFilters() {
    const url = new URL(window.location.href);
    const view = url.searchParams.get('view');
    url.search = '';
    if (view === 'map') url.searchParams.set('view', 'map');
    window.history.replaceState({}, '', url.toString());
    lastSmartParse = null;
    dispatchFiltersChanged();
  }

  /**
   * Live smart-search. Re-parses the current input on every keystroke and
   * diffs against the previous parse so:
   *   - Structured filters extracted by the parser stay in URL until the
   *     phrase that produced them is no longer present in the input.
   *   - Filters the user picked manually via pills/checkboxes are never
   *     touched (we only add/remove our own previously-applied values).
   *   - `q` is set to the leftover text only — never the full input — so
   *     a query like "date night" doesn't double-filter (vibe=date-spot
   *     filter PLUS a text-search for "night" that matches nothing).
   *   - Clearing the input wipes everything we contributed in one shot.
   */
  function runLiveSmartParse(value: string) {
    const ref = (window as { __lucaseatsRefData?: SmartParseRefData }).__lucaseatsRefData;
    const url = new URL(window.location.href);

    if (!ref) {
      // Reference data not yet shipped — fall back to plain text search.
      url.searchParams.delete('q');
      if (value) url.searchParams.set('q', value);
      window.history.replaceState({}, '', url.toString());
      dispatchFiltersChanged();
      return;
    }

    const parsed = smartParse(value, ref);

    // Drop anything the previous parse contributed that the current one
    // doesn't. Skips manual user picks because they were never in
    // lastSmartParse to begin with.
    if (lastSmartParse) {
      const drop = (name: string, value: string) => {
        const all = url.searchParams.getAll(name);
        url.searchParams.delete(name);
        for (const v of all) if (v !== value) url.searchParams.append(name, v);
      };
      for (const c of lastSmartParse.cuisines) {
        if (!parsed.cuisines.includes(c)) drop('cuisine', c);
      }
      for (const r of lastSmartParse.regions) {
        if (!parsed.regions.includes(r)) drop('location', `region:${r}`);
      }
      for (const s of lastSmartParse.suburbs) {
        if (!parsed.suburbs.includes(s)) drop('location', s);
      }
      for (const v of lastSmartParse.vibes) {
        if (!parsed.vibes.includes(v)) drop('vibes', v);
      }
      for (const p of lastSmartParse.price ?? []) {
        if (!parsed.price.includes(p)) drop('price', String(p));
      }
      if (lastSmartParse.meal && lastSmartParse.meal !== parsed.meal) {
        if (url.searchParams.get('meal') === lastSmartParse.meal) {
          url.searchParams.delete('meal');
        }
      }
    }

    // Add anything new from this parse (skip if the value's already there).
    const addUnique = (name: string, value: string) => {
      if (!url.searchParams.getAll(name).includes(value)) {
        url.searchParams.append(name, value);
      }
    };
    for (const c of parsed.cuisines) addUnique('cuisine', c);
    for (const r of parsed.regions) addUnique('location', `region:${r}`);
    for (const s of parsed.suburbs) addUnique('location', s);
    for (const v of parsed.vibes) addUnique('vibes', v);
    for (const p of parsed.price) addUnique('price', String(p));
    if (parsed.meal) url.searchParams.set('meal', parsed.meal);

    // q gets only the leftover. The full original stays visible in the
    // search input so the user can see their query.
    url.searchParams.delete('q');
    if (parsed.remaining) url.searchParams.set('q', parsed.remaining);

    window.history.replaceState({}, '', url.toString());
    lastSmartParse = parsed.matched ? parsed : null;
    dispatchFiltersChanged();
  }

  function initFilterBar() {
    const form = document.querySelector<HTMLFormElement>('.filter-bar');
    if (!form) return;

    // Live smart-search — every keystroke runs the parser so structured
    // tokens light up filter pills as the user types, and the leftover
    // (with stopwords stripped) becomes the q text-search. Same handler
    // for both Enter (form submit) and live typing — they're equivalent.
    form.addEventListener('submit', (e) => {
      e.preventDefault();
      const q = form.querySelector<HTMLInputElement>('input[name="q"]');
      runLiveSmartParse(q?.value.trim() ?? '');
      // Drop focus so the on-screen keyboard tucks away on mobile —
      // results are below the input, the user is done typing.
      q?.blur();
    });
    const qInput = form.querySelector<HTMLInputElement>('input[name="q"]');
    const clearBtn = form.querySelector<HTMLButtonElement>('[data-search-clear]');
    const syncClearBtn = () => {
      if (!clearBtn || !qInput) return;
      clearBtn.toggleAttribute('hidden', !qInput.value);
    };
    if (qInput) {
      let t: ReturnType<typeof setTimeout> | null = null;
      qInput.addEventListener('input', () => {
        syncClearBtn();
        if (t) clearTimeout(t);
        t = setTimeout(() => runLiveSmartParse(qInput.value.trim()), 180);
      });
      syncClearBtn();
    }
    if (clearBtn && qInput) {
      clearBtn.addEventListener('click', () => {
        qInput.value = '';
        syncClearBtn();
        clearAllFilters();
        qInput.focus();
      });
    }

    const pillSelects = form.querySelectorAll<HTMLDivElement>('.pill-select');
    const closeAllPanels = () => {
      pillSelects.forEach((sel) => {
        const panel = sel.querySelector<HTMLDivElement>('.panel');
        if (panel) panel.hidden = true;
      });
    };
    pillSelects.forEach((sel) => {
      const trigger = sel.querySelector<HTMLButtonElement>('[data-pill-trigger]');
      const panel = sel.querySelector<HTMLDivElement>('.panel');
      if (!trigger || !panel) return;
      const paramName = sel.dataset.name ?? '';
      const isMulti = sel.dataset.multi !== undefined;

      trigger.addEventListener('click', (e) => {
        e.stopPropagation();
        const wasOpen = !panel.hidden;
        closeAllPanels();
        panel.hidden = wasOpen;
      });

      panel.querySelectorAll<HTMLButtonElement>('.opt').forEach((opt) => {
        opt.addEventListener('click', (e) => {
          e.stopPropagation();
          // "Clear all" button on a multi-pill clears every value of the
          // associated URL param.
          if (opt.dataset.clearThis !== undefined) {
            setSingleParam(paramName, '');
            return;
          }
          // Multi-select option — toggle this single value, leave panel open.
          if (opt.dataset.multiValue !== undefined) {
            const value = opt.dataset.multiValue;
            const willBeOn = !opt.classList.contains('on');
            opt.classList.toggle('on', willBeOn);
            opt.setAttribute('aria-checked', willBeOn ? 'true' : 'false');
            toggleMultiParam(paramName, value, willBeOn);
            return;
          }
          // Single-select option (sort, status) — set and close.
          const value = opt.dataset.value ?? '';
          panel.hidden = true;
          setSingleParam(paramName, value);
          // Update local .on state immediately so the panel reflects the pick
          // even before the next applyFilters tick.
          panel.querySelectorAll<HTMLElement>('.opt').forEach((o) => {
            if (o.dataset.value !== undefined) {
              o.classList.toggle('on', (o.dataset.value ?? '') === value);
            }
          });
          // Hint to the rest of the page (the multi-pill code path doesn't
          // need this since the change-event already kicked it off).
          void isMulti;
        });
      });
    });

    const topRatedBtn = form.querySelector<HTMLButtonElement>('[data-top-rated]');
    const topRatedHidden = form.querySelector<HTMLInputElement>('input[name="minRating"]');
    if (topRatedBtn && topRatedHidden) {
      topRatedBtn.addEventListener('click', () => {
        const wasOn = topRatedHidden.value !== '';
        const nextVal = wasOn ? '' : '7';
        topRatedHidden.value = nextVal;
        topRatedBtn.classList.toggle('on', !wasOn);
        topRatedBtn.setAttribute('aria-pressed', wasOn ? 'false' : 'true');
        const check = topRatedBtn.querySelector<HTMLElement>('.check');
        if (check) check.textContent = wasOn ? '' : '✓';
        setSingleParam('minRating', nextVal);
      });
    }

    form.querySelectorAll<HTMLInputElement>('.vibe-chip input, .price-chip input').forEach((cb) => {
      cb.addEventListener('change', () => {
        toggleMultiParam(cb.name, cb.value, cb.checked);
        const label = cb.closest<HTMLLabelElement>('label');
        if (label) label.classList.toggle('on', cb.checked);
      });
    });

    // Active-chip removal is handled by /all.astro's document-level click
    // delegator (it covers desktop + mobile chips uniformly). No per-chip
    // listener needed here.
  }

  // Fires on initial load and after every View Transitions swap.
  document.addEventListener('astro:page-load', initFilterBar);
</script>

